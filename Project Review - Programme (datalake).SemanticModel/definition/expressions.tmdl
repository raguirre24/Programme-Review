expression dbo_project =
		let
		    Source = AmazonAthena.Databases("primary_p6_bi_reporting", null, [EnableNativeQuery = true]),
		    AwsDataCatalog_Database = Source{[Name="AwsDataCatalog",Kind="Database"]}[Data],
		    prod_projectcontrols_linkedsitereports_Schema1 = AwsDataCatalog_Database{[Name="prod_projectcontrols_linkedsitereports",Kind="Schema"]}[Data],
		    dbo_project_Table = prod_projectcontrols_linkedsitereports_Schema1{[Name="dbo_project",Kind="Table"]}[Data],
		    #"Removed Other Columns" = Table.SelectColumns(dbo_project_Table,{"projectno", "projectname", "state"})
		in
		    #"Removed Other Columns"
