expression SelectedProjects = "C4068, C5064" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: a1b2c3d4-5e6f-7a8b-9c0d-ef1234567890
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

expression ProjectFilterList =
		let
		    Raw = Text.Trim(SelectedProjects),
		    Tokens =
		        List.Select(
		            List.Transform(Text.Split(Raw, ","), each Text.Trim(_)),
		            each _ <> ""
		        ),
		    UpperTokens = List.Transform(Tokens, each Text.Upper(_)),
		    Result =
		        if List.Count(Tokens) = 0 then
		            error "SelectedProjects must contain a comma-separated list of project codes or ALL."
		        else if List.Count(Tokens) = 1 and UpperTokens{0} = "ALL" then
		            null
		        else if List.Contains(UpperTokens, "ALL") then
		            error "Use ALL by itself, not mixed with project codes."
		        else
		            List.Sort(List.Distinct(Tokens))
		in
		    Result
	lineageTag: b2c3d4e5-6f7a-8b9c-0d1e-f23456789012
	queryGroup: Database

	annotation PBI_ResultType = List

	annotation PBI_NavigationStepName = Navigation

expression AthenaScopeSql =
		let
		    ProgTypeRaw = Text.Upper(Text.Trim(SelectedProgrammeType)),
		    ProgType =
		        if List.Contains({"C", "T", "ALL"}, ProgTypeRaw) then
		            ProgTypeRaw
		        else
		            error "SelectedProgrammeType must be C, T, or ALL.",

		    FilterList = ProjectFilterList,

		    QuoteText = (value as text) as text =>
		        "'" & Text.Replace(value, "'", "''") & "'",

		    ProgrammeTypeFilter =
		        if ProgType = "ALL" then
		            "SPLIT_PART(filename, '-', 2) IN ('C', 'T')"
		        else
		            "SPLIT_PART(filename, '-', 2) = " & QuoteText(ProgType),

		    ProjectFilter =
		        if FilterList = null then
		            ""
		        else
		            " AND SPLIT_PART(filename, '-', 1) IN (" &
		            Text.Combine(List.Transform(FilterList, each QuoteText(_)), ", ") &
		            ")",

		    Sql =
		        "WITH " &
		        "parsed AS (" &
		            "SELECT proj_short_name, filename, last_recalc_date, " &
		            "REGEXP_REPLACE(filename, '_[0-9]{8}\.xer$', '') AS filename_stem, " &
		            "SPLIT_PART(filename, '-', 1) AS project_code, " &
		            "SPLIT_PART(filename, '-', 2) AS programme_type, " &
		            "SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3) AS tag, " &
		            "CASE WHEN REGEXP_LIKE(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), '^BL[0-9]+') THEN TRUE ELSE FALSE END AS is_baseline, " &
		            "CASE WHEN REGEXP_LIKE(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), '^BL[0-9]+') THEN CAST(REGEXP_EXTRACT(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), 'BL([0-9]+)', 1) AS INTEGER) END AS bl_number " &
		            "FROM prod_projectcontrols_p6.""02_xer_project"" " &
		            "WHERE " & ProgrammeTypeFilter & ProjectFilter &
		        "), " &
		        "parent_ranked AS (" &
		            "SELECT filename, proj_short_name, last_recalc_date, " &
		            "REGEXP_EXTRACT(proj_short_name, 'BL[0-9]+-([A-Z])$', 1) AS bl_revision, " &
		            "ROW_NUMBER() OVER (" &
		                "PARTITION BY filename " &
		                "ORDER BY " &
		                    "CASE WHEN proj_short_name = filename_stem THEN 0 ELSE 1 END, " &
		                    "LENGTH(proj_short_name), " &
		                    "proj_short_name" &
		            ") AS parent_rank " &
		            "FROM parsed " &
		            "WHERE proj_short_name = filename_stem OR proj_short_name LIKE filename_stem || '-%'" &
		        "), " &
		        "parent_map AS (" &
		            "SELECT filename, " &
		            "last_recalc_date AS parent_recalc_date, " &
		            "NULLIF(bl_revision, '') AS bl_revision " &
		            "FROM parent_ranked " &
		            "WHERE parent_rank = 1" &
		        "), " &
		        "file_info AS (" &
		            "SELECT DISTINCT p.filename, p.project_code, p.programme_type, " &
		            "p.is_baseline, p.bl_number, " &
		            "pm.parent_recalc_date, pm.bl_revision " &
		            "FROM parsed p " &
		            "LEFT JOIN parent_map pm ON p.filename = pm.filename" &
		        "), " &
		        "ranked_baselines AS (" &
		            "SELECT *, ROW_NUMBER() OVER (" &
		                "PARTITION BY project_code, programme_type " &
		                "ORDER BY bl_number DESC, " &
		                    "bl_revision DESC NULLS LAST, " &
		                    "parent_recalc_date DESC NULLS LAST, " &
		                    "filename DESC" &
		            ") AS bl_rank " &
		            "FROM file_info " &
		            "WHERE is_baseline = TRUE" &
		        "), " &
		        "latest_baseline AS (" &
		            "SELECT project_code, programme_type, " &
		            "parent_recalc_date AS anchor_date, filename AS anchor_filename " &
		            "FROM ranked_baselines " &
		            "WHERE bl_rank = 1" &
		        "), " &
		        "kept_filenames AS (" &
		            "SELECT DISTINCT f.filename, f.parent_recalc_date " &
		            "FROM file_info f " &
		            "LEFT JOIN latest_baseline lb " &
		                "ON f.project_code = lb.project_code " &
		                "AND f.programme_type = lb.programme_type " &
		            "WHERE " &
		                "lb.anchor_date IS NULL " &
		                "OR f.filename = lb.anchor_filename " &
		                "OR (f.is_baseline = FALSE AND f.parent_recalc_date > lb.anchor_date) " &
		                "OR f.parent_recalc_date IS NULL" &
		        ") "
		in
		    Sql
	lineageTag: 697373d3-5d41-4354-ad93-6757a27eefee
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

expression fnAthenaSource =
		let
		    fn = (tableName as text, optional selectList as nullable text) as table =>
		        let
		            DB = AthenaDB,
		
		            AllowedChars =
		                List.Combine({
		                    List.Transform({48..57}, each Character.FromNumber(_)),
		                    List.Transform({65..90}, each Character.FromNumber(_)),
		                    List.Transform({97..122}, each Character.FromNumber(_)),
		                    {"_"}
		                }),
		
		            SafeTableName =
		                if Text.Length(tableName) > 0 and Text.Length(Text.Remove(tableName, AllowedChars)) = 0 then
		                    tableName
		                else
		                    error "Invalid table name.",
		
		            SelectClause =
		                if selectList = null or Text.Trim(selectList) = "" then
		                    "t.*"
		                else
		                    selectList,
		
		            Sql =
		                AthenaScopeSql &
		                "SELECT " & SelectClause & " " &
		                "FROM prod_projectcontrols_p6.""" & SafeTableName & """ t " &
		                "INNER JOIN kept_filenames kf ON t.filename = kf.filename",
		
		            Result = Value.NativeQuery(DB, Sql, null)
		        in
		            Result
		in
		    fn
	lineageTag: 6869b75f-be7a-43ff-a8eb-4ab5b098f358
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

expression AthenaDB =
		// Query Name: AthenaDB
		let
		    Source = AmazonAthena.Databases("primary_p6_bi_reporting", null, [EnableNativeQuery = true]),
		    DB = Source{[Name="AwsDataCatalog",Kind="Database"]}[Data]
		in
		    DB
