expression Staging_Calendar_Exceptions =
		let
		    Source = #"11_XER_CALENDAR_DETAILED",
		    Filtered = Table.SelectRows(Source, each
		        ([exception_type] = "Holiday" or [exception_type] = "Exception - Working")
		        and [date] <> null
		    ),
		    Narrow = Table.SelectColumns(Filtered, {"clndr_id_key", "date", "working_day_int"})
		in
		    Narrow
