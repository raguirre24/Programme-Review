expression Staging_Calendar_Standard =
		let
		    Source = #"11_XER_CALENDAR_DETAILED",
		    Filtered = Table.SelectRows(Source, each
		        [exception_type] = "Standard"
		        and [date] = null
		        and [working_day_int] = 1
		    ),
		    Narrow = Table.SelectColumns(Filtered, {"clndr_id_key", "day_of_week_num"})
		in
		    Narrow
