expression SelectedProjects = "C5064, C4036" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: a1b2c3d4-5e6f-7a8b-9c0d-ef1234567890
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

expression ProjectFilterList =
		let
		    raw = SelectedProjects,
		    isAll = Text.Upper(Text.Trim(raw)) = "ALL",
		    splitList = if isAll then null else List.Transform(Text.Split(raw, ","), each Text.Trim(_))
		in
		    splitList
	lineageTag: b2c3d4e5-6f7a-8b9c-0d1e-f23456789012
	queryGroup: Database

	annotation PBI_ResultType = List

	annotation PBI_NavigationStepName = Navigation

expression fnFilterByFilename =
		let
		    fn = (sourceTable as table, filenameColumn as text, delimiter as text) as table =>
		        let
		            filterList = ProjectFilterList,
		            result = if filterList = null then
		                sourceTable
		            else
		                Table.SelectRows(sourceTable, each List.Contains(filterList, Text.Trim(Text.BeforeDelimiter(Record.Field(_, filenameColumn), delimiter))))
		        in
		            result
		in
		    fn
	lineageTag: c3d4e5f6-7a8b-9c0d-1e2f-345678901234
	queryGroup: Database

	annotation PBI_ResultType = Function

	annotation PBI_NavigationStepName = Navigation

expression fnAthenaSource =
		let
		    fn = (tableName as text) as table =>
		        let
		            DB = AthenaDB,
		
		            filterList = ProjectFilterList,
		
		            baseWhere = "WHERE filename LIKE '%-C-%'",
		
		            projectWhere =
		                if filterList = null then
		                    ""
		                else
		                    let
		                        quoted = List.Transform(filterList, each
		                            "'" & Text.Replace(_, "'", "''") & "'"
		                        ),
		                        inClause = Text.Combine(quoted, ", ")
		                    in
		                        " AND SPLIT_PART(filename, '-', 1) IN (" & inClause & ")",
		
		            sql = "SELECT * FROM prod_projectcontrols_p6.""" & tableName & """ " & baseWhere & projectWhere,
		
		            Result = Value.NativeQuery(DB, sql)
		        in
		            Result
		in
		    fn
	lineageTag: 6869b75f-be7a-43ff-a8eb-4ab5b098f358
	queryGroup: Database

