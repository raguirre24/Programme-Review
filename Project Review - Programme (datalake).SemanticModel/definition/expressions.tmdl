expression SelectedProjects = "C4068, C5064" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: a1b2c3d4-5e6f-7a8b-9c0d-ef1234567890
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

expression ProjectFilterList =
		let
		    raw = SelectedProjects,
		    isAll = Text.Upper(Text.Trim(raw)) = "ALL",
		    splitList = if isAll then null else List.Transform(Text.Split(raw, ","), each Text.Trim(_))
		in
		    splitList
	lineageTag: b2c3d4e5-6f7a-8b9c-0d1e-f23456789012
	queryGroup: Database

	annotation PBI_ResultType = List

	annotation PBI_NavigationStepName = Navigation

expression fnFilterByFilename =
		let
		    fn = (sourceTable as table, filenameColumn as text, delimiter as text) as table =>
		        let
		            filterList = ProjectFilterList,
		            result = if filterList = null then
		                sourceTable
		            else
		                Table.SelectRows(sourceTable, each List.Contains(filterList, Text.Trim(Text.BeforeDelimiter(Record.Field(_, filenameColumn), delimiter))))
		        in
		            result
		in
		    fn
	lineageTag: c3d4e5f6-7a8b-9c0d-1e2f-345678901234
	queryGroup: Database

	annotation PBI_ResultType = Function

	annotation PBI_NavigationStepName = Navigation

expression fnAthenaSource =
		let
		    fn = (tableName as text) as table =>
		        let
		            DB = AthenaDB,
		
		            // ── Programme Type Filter (C / T / ALL) ──
		            progType = Text.Upper(Text.Trim(SelectedProgrammeType)),
		            programmeTypeFilter =
		                if progType = "ALL" then "(filename LIKE '%-C-%' OR filename LIKE '%-T-%')"
		                else if progType = "T" then "filename LIKE '%-T-%'"
		                else "filename LIKE '%-C-%'",
		
		            // ── Project Filter ──
		            filterList = ProjectFilterList,
		            projectFilter =
		                if filterList = null then
		                    ""
		                else
		                    let
		                        quoted = List.Transform(filterList, each
		                            "'" & Text.Replace(_, "'", "''") & "'"
		                        ),
		                        inClause = Text.Combine(quoted, ", ")
		                    in
		                        " AND SPLIT_PART(filename, '-', 1) IN (" & inClause & ")",
		
		            // ── Athena CTE: kept_filenames ──
		            cte =
		                "WITH " &
		                "parsed AS (" &
		                    "SELECT filename, monthupdate, " &
		                    "SPLIT_PART(filename, '-', 1) AS project_code, " &
		                    "SPLIT_PART(filename, '-', 2) AS programme_type, " &
		                    "SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3) AS tag, " &
		                    "CASE WHEN REGEXP_LIKE(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), '^BL[0-9]+') THEN TRUE ELSE FALSE END AS is_baseline, " &
		                    "CASE WHEN REGEXP_LIKE(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), '^BL[0-9]+') THEN CAST(REGEXP_EXTRACT(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), 'BL([0-9]+)', 1) AS INTEGER) END AS bl_number, " &
		                    "CASE WHEN REGEXP_LIKE(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 3), '^BL[0-9]+') THEN NULLIF(SPLIT_PART(SPLIT_PART(filename, '_', 1), '-', 4), '') END AS bl_revision " &
		                    "FROM prod_projectcontrols_p6.""02_xer_project"" " &
		                    "WHERE (" & programmeTypeFilter & ")" & projectFilter &
		                "), " &
		                "ranked_baselines AS (" &
		                    "SELECT *, ROW_NUMBER() OVER (PARTITION BY project_code, programme_type ORDER BY bl_number DESC, bl_revision DESC NULLS LAST, monthupdate DESC NULLS LAST) AS bl_rank " &
		                    "FROM parsed WHERE is_baseline = TRUE" &
		                "), " &
		                "latest_baseline AS (" &
		                    "SELECT project_code, programme_type, monthupdate AS anchor_date, filename AS anchor_filename " &
		                    "FROM ranked_baselines WHERE bl_rank = 1" &
		                "), " &
		                "kept_filenames AS (" &
		                    "SELECT DISTINCT p.filename " &
		                    "FROM parsed p " &
		                    "LEFT JOIN latest_baseline lb ON p.project_code = lb.project_code AND p.programme_type = lb.programme_type " &
		                    "WHERE lb.anchor_date IS NULL OR p.filename = lb.anchor_filename OR p.monthupdate > lb.anchor_date" &
		                ") ",
		
		            // ── Final query: CTE + INNER JOIN to target table ──
		            sql = cte & "SELECT t.* FROM prod_projectcontrols_p6.""" & tableName & """ t INNER JOIN kept_filenames kf ON t.filename = kf.filename",
		
		            Result = Value.NativeQuery(DB, sql)
		        in
		            Result
		in
		    fn
	lineageTag: 6869b75f-be7a-43ff-a8eb-4ab5b098f358
	queryGroup: Database

	annotation PBI_NavigationStepName = Navigation

