	column predecessor_task_code = LOOKUPVALUE('01 XER_TASK'[task_code],'01 XER_TASK'[Task_ID_key],[pred_task_id_key])
		lineageTag: f6f3a806-3c26-44ba-b90b-880b9a7eb127
