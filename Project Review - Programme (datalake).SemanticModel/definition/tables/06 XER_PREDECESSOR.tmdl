	partition '06 XER_PREDECESSOR' = m
		mode: import
		queryGroup: XER
		source =
				let
				    Source = fnAthenaSource("06_xer_predecessor"),
				
				    SelectedColumns =
				        Table.SelectColumns(Source,{"task_pred_id", "pred_type", "task_id_key", "pred_task_id_key", "status_code", "predecessor_status_code", "task_type", "predecessor_task_type", "lag", "start", "finish", "predecessor_start", "predecessor_finish", "free_float", "total_float", "filename"}),
				    #"Inserted Merged Column" = Table.AddColumn(SelectedColumns, "task_pred_id_key", each Text.Combine({[filename], [task_pred_id]}, "."), type text),
				
				    AddParsedColumns =
				        Table.ExpandRecordColumn(
				            Table.AddColumn(
				                #"Inserted Merged Column",
				                "Parsed",
				                each
				                    let
				                        FileName =
				                            if [filename] = null then
				                                null
				                            else
				                                Text.Trim([filename]),
				
				                        Prefix =
				                            if FileName <> null and Text.Contains(FileName, "_") then
				                                Text.BeforeDelimiter(FileName, "_")
				                            else
				                                FileName,
				
				                        Parts =
				                            if Prefix <> null then
				                                Text.Split(Prefix, "-")
				                            else
				                                {},
				
				                        ProjectCode =
				                            if List.Count(Parts) >= 1 then
				                                Parts{0}
				                            else
				                                null,
				
				                        CPart =
				                            if List.Count(Parts) >= 3 then
				                                Parts{2}
				                            else
				                                null,
				
				                        UpdateDate =
				                            if CPart = null or CPart = "" then
				                                null
				                            else if Text.StartsWith(CPart, "BL") then
				                                let
				                                    DatePart =
				                                        if FileName <> null and Text.Contains(FileName, "_") then
				                                            try Text.BeforeDelimiter(Text.AfterDelimiter(FileName, "_"), ".") otherwise null
				                                        else
				                                            null
				                                in
				                                    try Date.EndOfMonth(Date.From(DateTime.FromText(DatePart))) otherwise null
				                            else
				                                let
				                                    P1 = try Number.FromText(Text.Start(CPart, 2)) otherwise null,
				                                    P2 = try Number.FromText(Text.End(CPart, 2)) otherwise null,
				                                    Yr = if P1 = null or P2 = null then null else if P2 > 12 then P2 else P1,
				                                    Mo = if P1 = null or P2 = null then null else if P2 > 12 then P1 else P2
				                                in
				                                    if Yr = null or Mo = null or Mo < 1 or Mo > 12 then
				                                        null
				                                    else
				                                        Date.EndOfMonth(#date(2000 + Yr, Mo, 1))
				                    in
				                        [
				                            ProjectCode = ProjectCode,
				                            UpdateDate = UpdateDate
				                        ],
				                type [
				                    ProjectCode = nullable text,
				                    UpdateDate = nullable date
				                ]
				            ),
				            "Parsed",
				            {"ProjectCode", "UpdateDate"},
				            {"ProjectCode", "UpdateDate"}
				        ),
				    #"Parsed Date" = Table.TransformColumns(AddParsedColumns,{{"start", each Date.From(DateTimeZone.From(_)), type date}, {"finish", each Date.From(DateTimeZone.From(_)), type date}, {"predecessor_start", each Date.From(DateTimeZone.From(_)), type date}, {"predecessor_finish", each Date.From(DateTimeZone.From(_)), type date}}),
				
				    Typed =
				        Table.TransformColumnTypes(
				            #"Parsed Date",
				            {
				                {"lag", type number},
				                {"free_float", type number},
				                {"total_float", type number},
				                {"UpdateDate", type date}
				            }
				        ),
				    #"Removed Columns" = Table.RemoveColumns(Typed,{"task_pred_id", "filename"})
				in
				    #"Removed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

