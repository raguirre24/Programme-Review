	column 'Baseline Start' =
			
			VAR CurrentTaskCode = '06 XER_PREDECESSOR'[task_code]
			VAR CurrentProject = '06 XER_PREDECESSOR'[ProjectCode]
			
			RETURN
			    MAXX(
			        FILTER(
			            ALL('04 XER_BASELINE'),
			            '04 XER_BASELINE'[task_code] = CurrentTaskCode &&
			            '04 XER_BASELINE'[ProjectCode] = CurrentProject
			        ),
			        '04 XER_BASELINE'[early_start_date]
			    )
		lineageTag: 4437b4bd-ccc3-45ee-aa72-74825c4fd048
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Baseline Finish' =
			
			VAR CurrentTaskCode = '06 XER_PREDECESSOR'[task_code]
			VAR CurrentProject = '06 XER_PREDECESSOR'[ProjectCode]
			
			RETURN
			    MAXX(
			        FILTER(
			            ALL('04 XER_BASELINE'),
			            '04 XER_BASELINE'[task_code] = CurrentTaskCode &&
			            '04 XER_BASELINE'[ProjectCode] = CurrentProject
			        ),
			        '04 XER_BASELINE'[early_end_date]
			    )
		lineageTag: 523861ed-a746-484b-87f0-36c627742b32
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Previous Update Start' =
			
			VAR CurrentTaskCode = '06 XER_PREDECESSOR'[task_code]
			VAR CurrentProject = '06 XER_PREDECESSOR'[ProjectCode]
			VAR CurrentMonthUpdate = '06 XER_PREDECESSOR'[UpdateDate]
			-- Find the previous month update (closest but less than current)
			VAR PreviousMonthUpdate =
			CALCULATE(
			MAX('01 XER_TASK'[UpdateDate]),
			FILTER(
			ALL('01 XER_TASK'),
			'01 XER_TASK'[task_code] = CurrentTaskCode &&
			'01 XER_TASK'[ProjectCode] = CurrentProject &&
			'01 XER_TASK'[UpdateDate] < CurrentMonthUpdate
			)
			)
			-- Get the Start date from the previous month update
			RETURN
			CALCULATE(
			MAX('01 XER_TASK'[early_start_date]),
			FILTER(
			ALL('01 XER_TASK'),
			'01 XER_TASK'[task_code] = CurrentTaskCode &&
			'01 XER_TASK'[ProjectCode] = CurrentProject &&
			'01 XER_TASK'[UpdateDate] = PreviousMonthUpdate
			)
			)
		formatString: dd/mm/yyyy
		lineageTag: 1eabe51d-e8c4-4329-a971-0d89b1f10c71
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column 'Previous Update Finish' = ```
			
			VAR CurrentTaskCode = '06 XER_PREDECESSOR'[task_code]
			VAR CurrentProject = '06 XER_PREDECESSOR'[ProjectCode]
			VAR CurrentMonthUpdate = '06 XER_PREDECESSOR'[UpdateDate]
			
			-- Find the previous month update (closest but less than current)
			VAR PreviousMonthUpdate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        FILTER(
			            ALL('01 XER_TASK'),
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectCode] = CurrentProject &&
			            '01 XER_TASK'[UpdateDate] < CurrentMonthUpdate
			        )
			    )
			
			-- Get the Start date from the previous month update
			RETURN
			    CALCULATE(
			        MAX('01 XER_TASK'[early_end_date]),
			        FILTER(
			            ALL('01 XER_TASK'),
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectCode] = CurrentProject &&
			            '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate
			        )
			    )
			```
		formatString: dd/mm/yyyy
		lineageTag: 0b0776b0-4580-474d-9450-afe4210a8ac1
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column Successor_Level_2 = ```
			
			VAR SuccTaskID = '06 XER_PREDECESSOR'[task_id_key]
			VAR SuccessorWBS_ID = 
			    CALCULATE(
			        SELECTEDVALUE('01 XER_TASK'[wbs_id_key]),
			        FILTER(
			            ALL('01 XER_TASK'),
			            '01 XER_TASK'[task_id_key] = SuccTaskID
			        )
			    )
			VAR SuccLevel2 = 
			    IF(
			        NOT ISBLANK(SuccessorWBS_ID),
			        CALCULATE(
			            MINX(
			                FILTER(
			                    ALL('03 XER_PROJWBS'),
			                    '03 XER_PROJWBS'[wbs_id_key] = SuccessorWBS_ID
			                ),
			                '03 XER_PROJWBS'[Level_2]
			            )
			        )
			    )
			RETURN
			    SuccLevel2
			```
		lineageTag: edd8bac4-29f2-4178-9030-2130db1006ed
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Predecessor_Level_2 = ```
			
			VAR PredTaskID = '06 XER_PREDECESSOR'[pred_task_id_key]
			VAR PredecessorWBS_ID = 
			    CALCULATE(
			        SELECTEDVALUE('01 XER_TASK'[wbs_id_key]),
			        FILTER(
			            ALL('01 XER_TASK'),
			            '01 XER_TASK'[task_id_key] = PredTaskID
			        )
			    )
			VAR PredLevel2 = 
			    IF(
			        NOT ISBLANK(PredecessorWBS_ID),
			        CALCULATE(
			            MINX(
			                FILTER(
			                    ALL('03 XER_PROJWBS'),
			                    '03 XER_PROJWBS'[wbs_id_key] = PredecessorWBS_ID
			                ),
			                '03 XER_PROJWBS'[Level_2]
			            )
			        )
			    )
			RETURN
			    PredLevel2
			```
		lineageTag: 1cfa0aa8-f050-434a-8ad5-40c9f5725f1f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Link_Type =
			
			IF(
			    '06 XER_PREDECESSOR'[Successor_Level_2] = '06 XER_PREDECESSOR'[Predecessor_Level_2],
			    "Internal Link",
			    "Cross-WBS Link"
			)
		lineageTag: 95640178-8db4-4f4c-8273-243f59583603
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column WBS_Link_Direction =
			
			'06 XER_PREDECESSOR'[Predecessor_Level_2] & " → " & '06 XER_PREDECESSOR'[Successor_Level_2]
		lineageTag: de16278c-97f0-4bd4-86cc-fc20a5bfd566
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column CriticalLink = ```
			
			VAR crit_succ = 
			    LOOKUPVALUE(
			        '01 XER_TASK'[CriticalStatus],
			        '01 XER_TASK'[task_id_key], '06 XER_PREDECESSOR'[task_id_key]
			    )
			VAR crit_pred = 
			    LOOKUPVALUE(
			        '01 XER_TASK'[CriticalStatus],
			        '01 XER_TASK'[task_id_key], '06 XER_PREDECESSOR'[pred_task_id_key]
			    )
			RETURN
			    IF(
			        NOT(ISBLANK(crit_pred)) && NOT(ISBLANK(crit_succ)),
			        crit_pred & " → " & crit_succ,
			        BLANK()
			    )
			```
		lineageTag: d5223047-9831-495c-a6a7-7598adab917f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Is Driving Predecessor' =
			
			VAR CurrentTaskID = '06 XER_PREDECESSOR'[task_id_key]
			VAR CurrentFreeFloat = '06 XER_PREDECESSOR'[free_float]
			
			VAR MinFreeFloatForTask =
			    CALCULATE (
			        MIN ( '06 XER_PREDECESSOR'[free_float] ),
			        FILTER (
			            ALL ( '06 XER_PREDECESSOR' ),
			            '06 XER_PREDECESSOR'[task_id_key] = CurrentTaskID
			        )
			    )
			
			RETURN
			    IF (
			        NOT ISBLANK ( CurrentFreeFloat ) && CurrentFreeFloat = MinFreeFloatForTask,
			        "Driving",
			        "Not Driving"
			    )
		lineageTag: 9c5ebbb1-dcd8-402b-861b-3e4b5fd11321
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Type Validity' =
			
			VAR taskType = '06 XER_PREDECESSOR'[task_type]
			VAR predTaskType = '06 XER_PREDECESSOR'[predecessor_task_type]
			VAR invalidTypes = { "TT_WBS", "TT_LOE" }
			
			RETURN
			    IF (
			        taskType IN invalidTypes || predTaskType IN invalidTypes,
			        "Invalid",
			        "Valid"
			    )
		lineageTag: 10c66ca2-309a-4bc6-bc92-0f0c44b0d730
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

