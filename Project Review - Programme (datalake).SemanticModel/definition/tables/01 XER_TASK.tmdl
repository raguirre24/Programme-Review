	column 'Float Category' = ```
			
			IF(
			    '01 XER_TASK'[status_code] = "Complete",
			    "Complete",
			    SWITCH(
			        TRUE(),
			        '01 XER_TASK'[total_float] < 0, " Float < 0",
			        '01 XER_TASK'[total_float] >= 0 && '01 XER_TASK'[total_float] <= 10, "0 ≤ Float ≤ 10",
			        '01 XER_TASK'[total_float] > 10 && '01 XER_TASK'[total_float] <= 30, "10 < Float ≤ 30",
			        '01 XER_TASK'[total_float] > 30 && '01 XER_TASK'[total_float] <= 50, "30 < Float ≤ 50",
			        '01 XER_TASK'[total_float] > 50, "50 < Float",
			        "Other Incomplete"
			    )
			)
			
			```
		lineageTag: a888ea7c-93cc-413b-a691-f95b0875b92e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column TaskType_Classified = ```
			
			SWITCH(
			    TRUE(),
			    '01 XER_TASK'[task_type] = "TT_Task", "Activity",
			    '01 XER_TASK'[task_type] = "TT_Rsrc", "Activity",
			    '01 XER_TASK'[task_type] = "TT_FinMile", "Milestone",
			    '01 XER_TASK'[task_type] = "TT_Mile", "Milestone",
			    '01 XER_TASK'[task_type] = "TT_LOE", "Level Of Effort",
			    '01 XER_TASK'[task_type] = "TT_WBS", "WBS Summary",
			    "Other"
			)
			
