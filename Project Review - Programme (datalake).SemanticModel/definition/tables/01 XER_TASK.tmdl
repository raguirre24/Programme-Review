	column Start_Variance_Previous_Month = ```
			
			VAR CurrentTaskCode = '01 XER_TASK'[task_code]
			VAR CurrentProjectName = '01 XER_TASK'[ProjectName]
			VAR CurrentMonthUpdate = '01 XER_TASK'[UpdateDate]
			VAR CurrentStartDate = '01 XER_TASK'[Start]
			
			VAR PreviousMonthUpdate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        FILTER(
			            '01 XER_TASK',
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectName] = CurrentProjectName &&
			            '01 XER_TASK'[UpdateDate] < CurrentMonthUpdate
			        )
			    )
			
			VAR PreviousStartDate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[Start]),
			        FILTER(
			            '01 XER_TASK',
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectName] = CurrentProjectName &&
			            '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate
			        )
			    )
			
			RETURN
			    IF(
			        NOT(ISBLANK(PreviousStartDate)) &&
			        NOT(ISBLANK(CurrentStartDate)),
			        IF(
			            PreviousStartDate = CurrentStartDate,
			            0,
			            NETWORKDAYS(PreviousStartDate, CurrentStartDate)
			        ),
			        0
			    )
			```
		formatString: 0
		lineageTag: cab1bd4a-03d4-4599-ad13-bfcc37c0d6ac
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column PreviousMonthStartVarianceCategory = ```
			
			    SWITCH(
			        TRUE(),
			        '01 XER_TASK'[Start_Variance_Previous_Month] = 0, "   No Variance",
			        '01 XER_TASK'[Start_Variance_Previous_Month] > 0 && '01 XER_TASK'[Start_Variance_Previous_Month] < 21, " <1 Month",
			        '01 XER_TASK'[Start_Variance_Previous_Month] >= 21 && '01 XER_TASK'[Start_Variance_Previous_Month] < 63, " 1-3 Months",
			        '01 XER_TASK'[Start_Variance_Previous_Month] >= 63 && '01 XER_TASK'[Start_Variance_Previous_Month] < 126, " 3-6 Months",
			        '01 XER_TASK'[Start_Variance_Previous_Month] >= 126, ">6 Months",
			        '01 XER_TASK'[Start_Variance_Previous_Month] < 0, "  Ahead",
			        BLANK()
			    )
			```
		lineageTag: b0f3aa18-1852-47d3-a513-3e54e95aab3d
		summarizeBy: none

