	column 'Planned Not Completed Last Period' = ```
			
			// 1. Get Current Row Context
			VAR CurrentProject = '01 XER_TASK'[ProjectName]
			VAR CurrentMonth = '01 XER_TASK'[UpdateDate]
			VAR CurrentDataDate = '01 XER_TASK'[data_date]
			VAR CurrentStatus = '01 XER_TASK'[status_code]
			
			// 2. Find Previous Month
			VAR PrevMonth = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName]),
			        '01 XER_TASK'[UpdateDate] < CurrentMonth
			    )
			
			// 3. Get Start of Window
			VAR PrevDataDate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[data_date]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName],'01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 4. Look up Previous Plan
			VAR PreviousTaskFinish = 
			    CALCULATE(
			        MAX('01 XER_TASK'[Finish]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName], '01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 5. Logic: Was it planned? AND Is it NOT Complete?
			VAR WasPlanned = 
			    PreviousTaskFinish > PrevDataDate && 
			    PreviousTaskFinish <= CurrentDataDate
			
			VAR IsNotComplete = 
			    CurrentStatus <> "Complete"
			
			RETURN
			    IF(NOT(ISBLANK(PrevMonth)) && WasPlanned && IsNotComplete, 1, 0)
			```
