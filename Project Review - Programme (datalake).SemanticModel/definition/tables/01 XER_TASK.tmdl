		formatString: MMM yy
		lineageTag: 99377e12-b3cb-4484-8650-e3e81f5b3f1c
		summarizeBy: none
		sourceColumn: UpdateDate

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

		annotation PBI_FormatHint = {"isCustom":true}

	column ProjectCode
		dataType: string
		lineageTag: fbbe2e5e-d874-421d-86b8-5f4a2a7e2b27
		summarizeBy: none
		sourceColumn: ProjectCode

		annotation SummarizationSetBy = Automatic

	column remaining_duration
		dataType: double
		lineageTag: 699a859d-06c4-433c-b859-48a4f23b1d4f
		summarizeBy: sum
		sourceColumn: remaining_duration

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column monthupdate
		dataType: string
		lineageTag: d0999a4f-5e63-4b8a-9a35-3ff4d279647b
		summarizeBy: none
		sourceColumn: monthupdate

		annotation SummarizationSetBy = Automatic

	partition '01 XER_TASK' = m
		mode: import
		queryGroup: XER
		source =
				let
				    Source = fnAthenaSource("01_xer_task"),
				
				    // Add ProjectCode + UpdateDate in one pass
				    AddParsedColumns = Table.AddColumn(
				        Table.AddColumn(Source, "ProjectCode", each Text.BeforeDelimiter([filename], "-"), type text),
				        "UpdateDate", each
				            let
				                parts = Text.Split(Text.BeforeDelimiter([filename], "_"), "-"),
				                cPart = if List.Count(parts) >= 3 then parts{2} else "",
				                datePart = Text.BeforeDelimiter(Text.AfterDelimiter([filename], "_"), ".")
				            in
				                if Text.StartsWith(cPart, "BL") then
				                    Date.EndOfMonth(Date.FromText(datePart))
				                else
				                    let
				                        p1 = Number.FromText(Text.Start(cPart, 2)),
				                        p2 = Number.FromText(Text.End(cPart, 2)),
				                        yr = if p2 > 12 then p2 else p1,
				                        mo = if p2 > 12 then p1 else p2
				                    in
				                        Date.EndOfMonth(#date(2000 + yr, mo, 1)),
				        type date
				    ),
				
				    // Transform percent_complete + all type conversions in one step
				    Typed = Table.TransformColumnTypes(
				        Table.TransformColumns(AddParsedColumns, {{"percent_complete", each Number.FromText(_) / 100}}),
				        {
				            {"act_start_date", type datetime}, {"act_end_date", type datetime},
				            {"early_start_date", type datetime}, {"early_end_date", type datetime},
				            {"late_start_date", type datetime}, {"late_end_date", type datetime},
				            {"target_start_date", type datetime}, {"target_end_date", type datetime},
				            {"cstr_date", type datetime}, {"start", type datetime}, {"finish", type datetime},
				            {"data_date", type datetime}, {"refresh_date", type datetime},
				            {"percent_complete", Percentage.Type},
				            {"total_float", type number}, {"free_float", type number},
				            {"remainingduration", type number}, {"original_duration", type number}
				        }
				    ),
				
				    // All renames consolidated
				    Renamed = Table.RenameColumns(Typed, {
				        {"start", "Start"}, {"finish", "Finish"}, {"remainingduration", "remaining_duration"}
				    }),
				
				    // --- PROJECT NAME LOOKUP WITH J-CODE FALLBACK ---
				
				    // Create the alternate code: replace leading "C" with "J"
				    AddAltCode = Table.AddColumn(
				        Renamed, "AltProjectCode",
				        each if Text.StartsWith([ProjectCode], "C") then
				                "J" & Text.Middle([ProjectCode], 1)
				             else
				                [ProjectCode],
				        type text
				    ),
				
				    BufferedProjects = Table.Buffer(dbo_project),
				
				    // 1) Try joining on the alternate J-code first
				    MergedAlt = Table.ExpandTableColumn(
				        Table.NestedJoin(AddAltCode, {"AltProjectCode"}, BufferedProjects, {"projectno"}, "AltLookup", JoinKind.LeftOuter),
				        "AltLookup", {"projectname"}, {"AltProjectName"}
				    ),
				
				    // 2) Also join on the original code as fallback
				    MergedOrig = Table.ExpandTableColumn(
				        Table.NestedJoin(MergedAlt, {"ProjectCode"}, BufferedProjects, {"projectno"}, "OrigLookup", JoinKind.LeftOuter),
				        "OrigLookup", {"projectname"}, {"OrigProjectName"}
				    ),
				
				    // 3) Pick the J-code name if it exists, otherwise fall back to original
				    AddProjectName = Table.AddColumn(
				        MergedOrig, "ProjectName",
				        each if [AltProjectName] <> null then [AltProjectName] else [OrigProjectName],
				        type text
				    ),
				
				    // Clean up helper columns
				    Cleanup = Table.RemoveColumns(AddProjectName, {"AltProjectCode", "AltProjectName", "OrigProjectName"})
				in
				    Cleanup

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

