	column StatusCategory =
			
			IF(
			    '01 XER_TASK'[status_code] = "Complete",
			    "Complete",
			    "Not Complete"
			)
		lineageTag: 4143997f-d77d-4c87-9b34-0e4dc77610e3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column CriticalStatus = ```
			
			VAR TaskStatus = TRIM(UPPER('01 XER_TASK'[status_code]))
			VAR FloatValue = '01 XER_TASK'[total_float]
			RETURN
			    IF(
			        TaskStatus <> "COMPLETE",
			        SWITCH(
			            TRUE(),
			            FloatValue <= 0, "Critical",
			            FloatValue > 0 && FloatValue <= 10, "Near Critical",
			            "Non-Critical"
			        ),
			        BLANK()
			    )
			
			```
		lineageTag: d8c504df-6a4d-49ad-9b83-1c8b123677b6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column FinishDateCategory = ```
			
			IF(
			   '01 XER_TASK'[status_code] <> "Complete",
			    VAR StartDate = '01 XER_TASK'[Finish]
			    VAR DataDate = '01 XER_TASK'[data_date]
			    VAR MonthsDifference = 
			        DATEDIFF(DataDate, StartDate, MONTH) + 
			        IF(DAY(StartDate) < DAY(DataDate), -1, 0)
			    RETURN
			        SWITCH(
			            TRUE(),
			            StartDate < DataDate, "Outside Range",
			            MonthsDifference < 1, " <1 Month",
			            MonthsDifference >= 1 && MonthsDifference < 3, " 1-3 Months",
			            MonthsDifference >= 3 && MonthsDifference < 6, " 3-6 Months",
			            MonthsDifference >= 6, ">6 Months",
			            BLANK()
			        ),
			    BLANK()
			)
			
			```
		lineageTag: b634f4d2-0ad4-4833-b622-257f56d60210
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column StartDateCategory = ```
			
			IF(
			    // Only proceed if task_type is "TT_Task" and Activity_Status is "Not Started"
			   '01 XER_TASK'[status_code] = "Not Started",
			    
			    // Define variables
			    VAR StartDate = '01 XER_TASK'[Start]
			    VAR DataDate = '01 XER_TASK'[data_date]
			    VAR MonthsDifference = 
			        DATEDIFF(DataDate, StartDate, MONTH) + 
			        IF(DAY(StartDate) < DAY(DataDate), -1, 0)
			    
			    // Return the category based on MonthsDifference
			    RETURN
			        SWITCH(
			            TRUE(),
			            StartDate < DataDate, "Outside Range",
			            MonthsDifference < 1, " <1 Month",
			            MonthsDifference >= 1 && MonthsDifference < 3, " 1-3 Months",
			            MonthsDifference >= 3 && MonthsDifference < 6, " 3-6 Months",
			            MonthsDifference >= 6, ">6 Months",
			            BLANK()
			        ),
			    
			    // If conditions are not met, return BLANK()
			    BLANK()
			)
			```
		lineageTag: b718f299-5eee-4a98-9cc9-369593fb4096
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'No Predecessor' = if(CALCULATE(COUNTA('06 XER_PREDECESSOR'[pred_task_id_key]))=BLANK(),1,0)
		formatString: 0
