	column PreviousDataDate =
			
			VAR CurrentDataDate = '01 XER_TASK'[data_date]
			VAR CurrentProject = '01 XER_TASK'[ProjectName]
			RETURN
			    MAXX(
			        FILTER(
			            ALL('01 XER_TASK'), -- Use ALL to remove existing filters on the table
			            '01 XER_TASK'[data_date] < CurrentDataDate &&
			            '01 XER_TASK'[ProjectName] = CurrentProject
			        ),
			        '01 XER_TASK'[data_date]
			    )
