		annotation SummarizationSetBy = Automatic

	partition '01 XER_TASK' = m
		mode: import
		queryGroup: XER
		source =
				let
				    fnParseFileName = (fileName as nullable text) as record =>
				        let
				            SafeFileName = if fileName = null then null else Text.Trim(fileName),
				
				            Prefix =
				                if SafeFileName <> null and Text.Contains(SafeFileName, "_") then
				                    Text.BeforeDelimiter(SafeFileName, "_")
				                else
				                    SafeFileName,
				
				            PrefixParts =
				                if Prefix <> null then
				                    Text.Split(Prefix, "-")
				                else
				                    {},
				
				            ProjectCode =
				                if SafeFileName <> null and Text.Contains(SafeFileName, "-") and List.Count(PrefixParts) >= 1 then
				                    PrefixParts{0}
				                else
				                    null,
				
				            ProgType =
				                if List.Count(PrefixParts) >= 2 then
				                    PrefixParts{1}
				                else
				                    null,
				
				            CPart =
				                if List.Count(PrefixParts) >= 3 then
				                    PrefixParts{2}
				                else
				                    null,
				
				            IsBL =
				                CPart <> null and Text.StartsWith(CPart, "BL"),
				
				            UpdateDate =
				                if CPart = null or CPart = "" or IsBL then
				                    null
				                else
				                    let
				                        P1 = try Number.FromText(Text.Start(CPart, 2)) otherwise null,
				                        P2 = try Number.FromText(Text.End(CPart, 2)) otherwise null,
				                        Yr = if P1 = null or P2 = null then null else if P2 > 12 then P2 else P1,
				                        Mo = if P1 = null or P2 = null then null else if P2 > 12 then P1 else P2
				                    in
				                        if Yr = null or Mo = null or Mo < 1 or Mo > 12 then
				                            null
				                        else
				                            Date.EndOfMonth(#date(2000 + Yr, Mo, 1))
				        in
				            [
				                ProjectCode = ProjectCode,
				                UpdateDate = UpdateDate,
				                _IsBL = IsBL,
				                _ProgType = ProgType
				            ],
				
				    // Robust date parser: handles null, native date/datetime/datetimezone,
				    // and text in several common Athena output formats. Culture-independent.
				    fnToDate = (value) as nullable date =>
				        if value = null then
				            null
				        else if Value.Is(value, type date) then
				            value
				        else if Value.Is(value, type datetime) or Value.Is(value, type datetimezone) then
				            try Date.From(value) otherwise null
				        else if Value.Is(value, type text) then
				            let
				                trimmed = Text.Trim(value),
				                // Athena timestamps commonly arrive as "yyyy-MM-dd HH:mm:ss[.fff]"
				                // or "yyyy-MM-ddTHH:mm:ss[Z]" — first 10 chars are the date part.
				                datePart =
				                    if Text.Length(trimmed) >= 10 then Text.Start(trimmed, 10) else trimmed,
				                parsed =
				                    try Date.FromText(datePart, [Format = "yyyy-MM-dd", Culture = "en-US"])
				                    otherwise try Date.FromText(datePart, [Format = "yyyy/MM/dd", Culture = "en-US"])
				                    otherwise try Date.From(trimmed)
				                    otherwise null
				            in
				                parsed
				        else
				            try Date.From(value) otherwise null,
				
				    SourceRaw = fnAthenaSource("01_xer_task", "t.*, kf.parent_recalc_date"),
				
				    Source =
				        Table.SelectColumns(
				            SourceRaw,
				            {
				                "status_code",
				                "task_code",
				                "total_float",
				                "task_type",
				                "id_name",
				                "early_start_date",
				                "calendar_id_key",
				                "task_id_key",
				                "driving_path_flag",
				                "remainingduration",
				                "early_end_date",
				                "monthupdate",
				                "task_name",
				                "data_date",
				                "act_end_date",
				                "finish",
				                "proj_id_key",
				                "wbs_id_key",
				                "free_float",
				                "cstr_type",
				                "start",
				                "filename",
				                "late_end_date",
				                "parent_recalc_date"
				            }
				        ),
				
				    AddParsedColumns =
				        Table.ExpandRecordColumn(
				            Table.AddColumn(
				                Source,
				                "Parsed",
				                each fnParseFileName([filename]),
				                type [
				                    ProjectCode = nullable text,
				                    UpdateDate = nullable date,
				                    _IsBL = logical,
				                    _ProgType = nullable text
				                ]
				            ),
				            "Parsed",
				            {"ProjectCode", "UpdateDate", "_IsBL", "_ProgType"},
				            {"ProjectCode", "UpdateDate", "_IsBL", "_ProgType"}
				        ),
				
				    ParentDateAsDate =
				        Table.TransformColumns(
				            AddParsedColumns,
				            {
				                {
				                    "parent_recalc_date",
				                    each fnToDate(_),
				                    type nullable date
				                }
				            }
				        ),
				
				    FillUpdateDate =
				        Table.RenameColumns(
				            Table.RemoveColumns(
				                Table.AddColumn(
				                    ParentDateAsDate,
				                    "UpdateDate_Final",
				                    each
				                        if [UpdateDate] = null and [parent_recalc_date] <> null then
				                            Date.EndOfMonth([parent_recalc_date])
				                        else
				                            [UpdateDate],
				                    type nullable date
				                ),
				                {"UpdateDate"}
				            ),
				            {{"UpdateDate_Final", "UpdateDate"}}
				        ),
				
				    NonBLDates =
				        Table.Group(
				            Table.SelectRows(
				                Table.SelectColumns(
				                    FillUpdateDate,
				                    {"ProjectCode", "_ProgType", "UpdateDate", "_IsBL"}
				                ),
				                each [_IsBL] = false and [UpdateDate] <> null
				            ),
				            {"ProjectCode", "_ProgType"},
				            {
				                {
				                    "_OccupiedDates",
				                    each List.Buffer(List.Distinct([UpdateDate])),
				                    type list
				                }
				            }
				        ),
				
				    WithOccupiedDates =
				        Table.ExpandTableColumn(
				            Table.NestedJoin(
				                FillUpdateDate,
				                {"ProjectCode", "_ProgType"},
				                NonBLDates,
				                {"ProjectCode", "_ProgType"},
				                "OccupiedLookup",
				                JoinKind.LeftOuter
				            ),
				            "OccupiedLookup",
				            {"_OccupiedDates"},
				            {"_OccupiedDates"}
				        ),
				
				    AdjustedUpdateDate =
				        Table.RenameColumns(
				            Table.RemoveColumns(
				                Table.AddColumn(
				                    WithOccupiedDates,
				                    "UpdateDate_Adjusted",
				                    each
				                        if [_IsBL] and [UpdateDate] <> null and [_OccupiedDates] <> null then
				                            let
				                                OccupiedDates = [_OccupiedDates],
				                                // Iteration cap prevents infinite recursion on corrupt data
				                                ShiftDate =
				                                    (d as date, iter as number) as nullable date =>
				                                        if iter > 240 then
				                                            d
				                                        else if List.Contains(OccupiedDates, d) then
				                                            @ShiftDate(Date.EndOfMonth(Date.AddMonths(d, -1)), iter + 1)
				                                        else
				                                            d
				                            in
				                                ShiftDate([UpdateDate], 0)
				                        else
				                            [UpdateDate],
				                    type nullable date
				                ),
				                {"UpdateDate"}
				            ),
				            {{"UpdateDate_Adjusted", "UpdateDate"}}
				        ),
				
				    Typed =
				        Table.TransformColumnTypes(
				            AdjustedUpdateDate,
				            {
				                {"act_end_date", type datetime},
				                {"UpdateDate", type date},
				                {"early_start_date", type datetime},
				                {"early_end_date", type datetime},
				                {"late_end_date", type datetime},
				                {"start", type datetime},
				                {"finish", type datetime},
				                {"data_date", type datetime},
				                {"total_float", type number},
				                {"free_float", type number},
				                {"remainingduration", type number}
				            }
				        ),
				
				    Renamed =
				        Table.RenameColumns(
				            Typed,
				            {
				                {"start", "Start"},
				                {"finish", "Finish"},
				                {"remainingduration", "remaining_duration"}
				            }
				        ),
				
				    AddAltCode =
				        Table.AddColumn(
				            Renamed,
				            "AltProjectCode",
				            each
				                if [ProjectCode] <> null and Text.StartsWith([ProjectCode], "C") then
				                    "J" & Text.Middle([ProjectCode], 1)
				                else
				                    [ProjectCode],
				            type nullable text
				        ),
				
				    BufferedProjects =
				        Table.Buffer(
				            Table.SelectColumns(
				                dbo_project,
				                {"projectno", "projectname"}
				            )
				        ),
				
				    MergedAlt =
				        Table.ExpandTableColumn(
				            Table.NestedJoin(
				                AddAltCode,
				                {"AltProjectCode"},
				                BufferedProjects,
				                {"projectno"},
				                "AltLookup",
				                JoinKind.LeftOuter
				            ),
				            "AltLookup",
				            {"projectname"},
				            {"AltProjectName"}
				        ),
				
				    MergedOrig =
				        Table.ExpandTableColumn(
				            Table.NestedJoin(
				                MergedAlt,
				                {"ProjectCode"},
				                BufferedProjects,
				                {"projectno"},
				                "OrigLookup",
				                JoinKind.LeftOuter
				            ),
				            "OrigLookup",
				            {"projectname"},
				            {"OrigProjectName"}
				        ),
				
				    AddProjectName =
				        Table.AddColumn(
				            MergedOrig,
				            "ProjectName",
				            each
				                if [AltProjectName] <> null then
				                    [AltProjectName]
				                else
				                    [OrigProjectName],
				            type nullable text
				        ),
				
				    Final =
				        Table.SelectColumns(
				            AddProjectName,
				            {
				                "status_code",
				                "task_code",
				                "total_float",
				                "task_type",
				                "ProjectName",
				                "id_name",
				                "early_start_date",
				                "calendar_id_key",
				                "task_id_key",
				                "driving_path_flag",
				                "remaining_duration",
				                "early_end_date",
				                "monthupdate",
				                "task_name",
				                "data_date",
				                "act_end_date",
				                "ProjectCode",
				                "Finish",
				                "proj_id_key",
				                "wbs_id_key",
				                "UpdateDate",
				                "free_float",
				                "cstr_type",
				                "Start",
				                "filename",
				                "late_end_date"
				            }
				        )
				in
				    Final

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

