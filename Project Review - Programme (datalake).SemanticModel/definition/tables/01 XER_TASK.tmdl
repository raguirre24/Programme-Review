	column Variance_Finish_BL = ```
			
			VAR TaskCode = '01 XER_TASK'[task_code]
			VAR ProjectName = '01 XER_TASK'[ProjectCode]
			VAR TaskFinishDate = '01 XER_TASK'[Finish]
			
			VAR BaselineFinishDate = 
			    MAXX(
			        FILTER(
			            ALL('04 XER_BASELINE'),
			            '04 XER_BASELINE'[task_code] = TaskCode &&
			            '04 XER_BASELINE'[ProjectCode] = ProjectName
			        ),
			        '04 XER_BASELINE'[Finish]
			    )
			
			// Adjust to handle the NETWORKDAYS off-by-one issue
			RETURN
			    IF(
			        NOT(ISBLANK(BaselineFinishDate)) && 
			        NOT(ISBLANK(TaskFinishDate)),
			        IF(
			            BaselineFinishDate = TaskFinishDate,
			            0,
			            NETWORKDAYS(BaselineFinishDate, TaskFinishDate)
			        ),
			        BLANK()
			    )
			```
		formatString: 0
		lineageTag: 0e8adf17-4283-49ba-8ca9-5f48c7067f76
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

