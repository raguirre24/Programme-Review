	column 'No Successor' =
			IF(
			    CALCULATE(
			        COUNTROWS('06 XER_PREDECESSOR'),
			        FILTER(
			            '06 XER_PREDECESSOR',
			            '06 XER_PREDECESSOR'[pred_task_id_key] = '01 XER_TASK'[task_id_key]
			        )
			    ) = BLANK(),
