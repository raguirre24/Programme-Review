	column 'Planned Last Period' = ```
			
			// 1. Get Current Row Context
			VAR CurrentProject = '01 XER_TASK'[ProjectName]
			VAR CurrentMonth = '01 XER_TASK'[UpdateDate]
			VAR CurrentDataDate = '01 XER_TASK'[data_date]
			
			// 2. Find Previous Month for this Project
			VAR PrevMonth = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName]),
			        '01 XER_TASK'[UpdateDate] < CurrentMonth
			    )
			
			// 3. Get the Start of the Window (Previous Data Date)
			VAR PrevDataDate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[data_date]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName],'01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 4. Look up the Scheduled Finish Date from the PREVIOUS Month's row
			VAR PreviousTaskFinish = 
			    CALCULATE(
			        MAX('01 XER_TASK'[Finish]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName], '01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 5. Logic: Was the previous planned finish inside the current window?
			VAR IsPlanned = 
			    PreviousTaskFinish > PrevDataDate && 
			    PreviousTaskFinish <= CurrentDataDate
			
			RETURN
			    IF(NOT(ISBLANK(PrevMonth)) && IsPlanned, 1, 0)
			```
		formatString: 0
		lineageTag: 7d9025b8-9b83-40bb-a7a7-dd03c9e5d223
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Completed Last Period' = ```
			
			// 1. Get Current Row Context
			VAR CurrentProject = '01 XER_TASK'[ProjectName]
			VAR CurrentTaskID = '01 XER_TASK'[task_code]  // You need a unique Task ID
			VAR CurrentMonth = '01 XER_TASK'[UpdateDate]
			VAR CurrentStatus = '01 XER_TASK'[status_code]
			
			// 2. Find the Previous Month available for this project
			VAR PrevMonth = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName]),
			        '01 XER_TASK'[UpdateDate] < CurrentMonth
			    )
			
			// 3. Look up what the status was in that previous month
			VAR PrevStatus = 
			    CALCULATE(
			        SELECTEDVALUE('01 XER_TASK'[status_code]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName]),
			        '01 XER_TASK'[task_code] = CurrentTaskID,
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 4. Logic: Is it Complete now AND was it something else before?
			VAR IsNewlyCompleted = 
			    CurrentStatus = "Complete" && 
			    PrevStatus <> "Complete" && 
			    NOT(ISBLANK(PrevStatus)) // Ensures we don't count brand new tasks as "Newly Completed"
			
			RETURN
			    IF(IsNewlyCompleted, 1, 0)
			```
		formatString: 0
		lineageTag: 66890f4d-b926-4890-ac92-dc3021681782
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Completed of Planned Last Period' = ```
			
			// 1. Get Current Row Context
			VAR CurrentProject = '01 XER_TASK'[ProjectName]
			VAR CurrentMonth = '01 XER_TASK'[UpdateDate]
			VAR CurrentDataDate = '01 XER_TASK'[data_date]
			VAR CurrentStatus = '01 XER_TASK'[status_code]
			
			// 2. Find Previous Month
			VAR PrevMonth = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName]),
			        '01 XER_TASK'[UpdateDate] < CurrentMonth
			    )
			
			// 3. Get Start of Window
			VAR PrevDataDate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[data_date]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName],'01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 4. Look up Previous Plan
			VAR PreviousTaskFinish = 
			    CALCULATE(
			        MAX('01 XER_TASK'[Finish]),
			        ALLEXCEPT('01 XER_TASK', '01 XER_TASK'[ProjectName], '01 XER_TASK'[Task_Code]),
			        '01 XER_TASK'[UpdateDate] = PrevMonth
			    )
			
			// 5. Logic: Was it planned? AND Is it Complete now?
			VAR WasPlanned = 
			    PreviousTaskFinish > PrevDataDate && 
			    PreviousTaskFinish <= CurrentDataDate
			
			VAR IsComplete = 
			    CurrentStatus = "Complete"
			
			RETURN
			    IF(NOT(ISBLANK(PrevMonth)) && WasPlanned && IsComplete, 1, 0)
			```
		formatString: 0
		lineageTag: aa1f9e14-7e09-47eb-87be-fb9371fcf07c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Baseline Effective_Early_End' =
			
