	column PreviousMonthFinishVarianceCategory = ```
			
			    SWITCH(
			        TRUE(),
			        '01 XER_TASK'[Finish_Variance_Previous_Month] = 0, "   No Variance",
			        '01 XER_TASK'[Finish_Variance_Previous_Month] > 0 && '01 XER_TASK'[Finish_Variance_Previous_Month] < 21, " <1 Month",
			        '01 XER_TASK'[Finish_Variance_Previous_Month] >= 21 && '01 XER_TASK'[Finish_Variance_Previous_Month] < 63, " 1-3 Months",
			        '01 XER_TASK'[Finish_Variance_Previous_Month] >= 63 && '01 XER_TASK'[Finish_Variance_Previous_Month] < 126, " 3-6 Months",
			        '01 XER_TASK'[Finish_Variance_Previous_Month] >= 126, ">6 Months",
			        '01 XER_TASK'[Finish_Variance_Previous_Month] < 0, "  Ahead",
			        BLANK()
			    )
			 
			```
		lineageTag: 239ae7b8-fd36-4e68-8b94-1e5eaaa1537a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Remaining Duration Category' =
			
			IF(
			    '01 XER_TASK'[status_code] = "Complete",
			    "Complete",
			    SWITCH(
			        TRUE(),
			        '01 XER_TASK'[remaining_duration] > 0 && '01 XER_TASK'[remaining_duration] <= 10, "0 < Dur. ≤ 10",
			        '01 XER_TASK'[remaining_duration] > 10 && '01 XER_TASK'[remaining_duration] <= 20, "10 < Dur. ≤ 20",
			        '01 XER_TASK'[remaining_duration] > 20 && '01 XER_TASK'[remaining_duration] <= 30, "20 < Dur. ≤ 30",
			        '01 XER_TASK'[remaining_duration] > 30 && '01 XER_TASK'[remaining_duration] <= 44, "30 < Dur. ≤ 44",
			        '01 XER_TASK'[remaining_duration] > 44, "44 < Dur.",
			        "Other Incomplete"
			    )
			)
