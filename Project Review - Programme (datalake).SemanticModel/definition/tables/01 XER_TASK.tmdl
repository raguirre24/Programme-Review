	column 'Adjusted Baseline Source'
		dataType: string
		lineageTag: 507f4253-f171-4828-9bdb-db511c4ea777
		summarizeBy: none
		sourceColumn: Adjusted Baseline Source

		annotation SummarizationSetBy = Automatic

	partition '01 XER_TASK' = m
		mode: import
		queryGroup: XER
		source =
				let
				    fnParseFileName = (fileName as nullable text) as record =>
				        let
				            SafeFileName = if fileName = null then null else Text.Trim(fileName),
				
				            Prefix =
				                if SafeFileName <> null and Text.Contains(SafeFileName, "_") then
				                    Text.BeforeDelimiter(SafeFileName, "_")
				                else
				                    SafeFileName,
				
				            PrefixParts =
				                if Prefix <> null then
				                    Text.Split(Prefix, "-")
				                else
				                    {},
				
				            ProjectCode =
				                if SafeFileName <> null and Text.Contains(SafeFileName, "-") and List.Count(PrefixParts) >= 1 then
				                    PrefixParts{0}
				                else
				                    null,
				
				            ProgType =
				                if List.Count(PrefixParts) >= 2 then
				                    PrefixParts{1}
				                else
				                    null,
				
				            CPart =
				                if List.Count(PrefixParts) >= 3 then
				                    PrefixParts{2}
				                else
				                    null,
				
				            IsBL =
				                CPart <> null and Text.StartsWith(CPart, "BL"),
				
				            UpdateDate =
				                if CPart = null or CPart = "" or IsBL then
				                    null
				                else
				                    let
				                        P1 = try Number.FromText(Text.Start(CPart, 2)) otherwise null,
				                        P2 = try Number.FromText(Text.End(CPart, 2)) otherwise null,
				                        Yr = if P1 = null or P2 = null then null else if P2 > 12 then P2 else P1,
				                        Mo = if P1 = null or P2 = null then null else if P2 > 12 then P1 else P2
				                    in
				                        if Yr = null or Mo = null or Mo < 1 or Mo > 12 then
				                            null
				                        else
				                            Date.EndOfMonth(#date(2000 + Yr, Mo, 1))
				        in
				            [
				                ProjectCode = ProjectCode,
				                UpdateDate = UpdateDate,
				                _IsBL = IsBL,
				                _ProgType = ProgType
				            ],
				
				    // Robust date parser: handles null, native date/datetime/datetimezone,
				    // and text in several common Athena output formats. Culture-independent.
				    fnToDate = (value) as nullable date =>
				        if value = null then
				            null
				        else if Value.Is(value, type date) then
				            value
				        else if Value.Is(value, type datetime) or Value.Is(value, type datetimezone) then
				            try Date.From(value) otherwise null
				        else if Value.Is(value, type text) then
				            let
				                trimmed = Text.Trim(value),
				                // Athena timestamps commonly arrive as "yyyy-MM-dd HH:mm:ss[.fff]"
				                // or "yyyy-MM-ddTHH:mm:ss[Z]" — first 10 chars are the date part.
				                datePart =
				                    if Text.Length(trimmed) >= 10 then Text.Start(trimmed, 10) else trimmed,
				                parsed =
				                    try Date.FromText(datePart, [Format = "yyyy-MM-dd", Culture = "en-US"])
				                    otherwise try Date.FromText(datePart, [Format = "yyyy/MM/dd", Culture = "en-US"])
				                    otherwise try Date.From(trimmed)
				                    otherwise null
				            in
				                parsed
				        else
				            try Date.From(value) otherwise null,
				
				    SourceRaw =
				        Value.NativeQuery(
				            AthenaDB,
				            Text.Combine(
				                {
				                    AthenaScopeSql,
				                    ", task_raw AS (",
				                    "SELECT ROW_NUMBER() OVER (ORDER BY t.""filename"", t.""task_id_key"", t.""task_code"", t.""start"", t.""finish"", t.""data_date"") AS task_row_id,",
				                    "t.""status_code"" AS status_code, t.""task_code"" AS task_code, TRY_CAST(t.""total_float"" AS DOUBLE) AS total_float, t.""task_type"" AS task_type,",
				                    "t.""id_name"" AS id_name, TRY_CAST(SUBSTR(CAST(t.""early_start_date"" AS VARCHAR), 1, 10) AS DATE) AS early_start_date, t.""calendar_id_key"" AS calendar_id_key, t.""task_id_key"" AS task_id_key,",
				                    "t.""driving_path_flag"" AS driving_path_flag, TRY_CAST(t.""remainingduration"" AS DOUBLE) AS remainingduration, TRY_CAST(SUBSTR(CAST(t.""early_end_date"" AS VARCHAR), 1, 10) AS DATE) AS early_end_date,",
				                    "TRY_CAST(SUBSTR(CAST(t.""monthupdate"" AS VARCHAR), 1, 10) AS DATE) AS monthupdate,",
				                    "t.""task_name"" AS task_name, TRY_CAST(SUBSTR(CAST(t.""data_date"" AS VARCHAR), 1, 10) AS DATE) AS data_date, TRY_CAST(SUBSTR(CAST(t.""act_end_date"" AS VARCHAR), 1, 10) AS DATE) AS act_end_date, TRY_CAST(SUBSTR(CAST(t.""finish"" AS VARCHAR), 1, 10) AS DATE) AS finish,",
				                    "t.""proj_id_key"" AS proj_id_key, t.""wbs_id_key"" AS wbs_id_key, TRY_CAST(t.""free_float"" AS DOUBLE) AS free_float, t.""cstr_type"" AS cstr_type,",
				                    "TRY_CAST(SUBSTR(CAST(t.""start"" AS VARCHAR), 1, 10) AS DATE) AS start, t.""filename"" AS filename, TRY_CAST(SUBSTR(CAST(t.""late_end_date"" AS VARCHAR), 1, 10) AS DATE) AS late_end_date,",
				                    "SPLIT_PART(SPLIT_PART(t.""filename"", '_', 1), '-', 1) AS project_code,",
				                    "SPLIT_PART(SPLIT_PART(t.""filename"", '_', 1), '-', 2) AS programme_type,",
				                    "SPLIT_PART(SPLIT_PART(t.""filename"", '_', 1), '-', 3) AS update_tag",
				                    "FROM prod_projectcontrols_p6.""01_xer_task"" t",
				                    "INNER JOIN kept_filenames kf ON t.""filename"" = kf.""filename""",
				                    "), task_update_parts AS (",
				                    "SELECT *,",
				                    "CASE WHEN update_tag IS NOT NULL AND REGEXP_LIKE(update_tag, '^BL') THEN TRUE ELSE FALSE END AS is_bl,",
				                    "TRY_CAST(NULLIF(REGEXP_EXTRACT(update_tag, '^([0-9]{2})', 1), '') AS INTEGER) AS tag_first_number,",
				                    "TRY_CAST(NULLIF(REGEXP_EXTRACT(update_tag, '([0-9]{2})$', 1), '') AS INTEGER) AS tag_last_number",
				                    "FROM task_raw",
				                    "), task_update_start AS (",
				                    "SELECT *,",
				                    "CASE WHEN tag_first_number IS NULL OR tag_last_number IS NULL THEN NULL WHEN tag_last_number > 12 THEN tag_last_number ELSE tag_first_number END AS update_year_number,",
				                    "CASE WHEN tag_first_number IS NULL OR tag_last_number IS NULL THEN NULL WHEN tag_last_number > 12 THEN tag_first_number ELSE tag_last_number END AS update_month_number",
				                    "FROM task_update_parts",
				                    "), task_with_update AS (",
				                    "SELECT *,",
				                    "CASE",
				                    "WHEN update_tag IS NULL OR update_tag = '' OR is_bl = TRUE THEN NULL",
				                    "WHEN update_month_number < 1 OR update_month_number > 12 OR update_year_number IS NULL THEN NULL",
				                    "ELSE CAST(date_add('day', -1, date_add('month', 1, date_trunc('month', TRY_CAST(CONCAT('20', LPAD(CAST(update_year_number AS VARCHAR), 2, '0'), '-', LPAD(CAST(update_month_number AS VARCHAR), 2, '0'), '-01') AS DATE)))) AS DATE)",
				                    "END AS parsed_update_date,",
				                    "CASE WHEN monthupdate IS NULL THEN NULL ELSE CAST(date_add('day', -1, date_add('month', 1, date_trunc('month', monthupdate))) AS DATE) END AS monthupdate_end_date",
				                    "FROM task_update_start",
				                    "), task_with_filled_update AS (",
				                    "SELECT *, COALESCE(parsed_update_date, monthupdate_end_date) AS update_date_filled",
				                    "FROM task_with_update",
				                    "), non_bl_dates AS (",
				                    "SELECT DISTINCT project_code, programme_type, update_date_filled AS update_date",
				                    "FROM task_with_filled_update",
				                    "WHERE is_bl = FALSE AND update_date_filled IS NOT NULL",
				                    "), update_candidates AS (",
				                    "SELECT u.task_row_id,",
				                    "CASE WHEN u.update_date_filled IS NULL THEN NULL ELSE CAST(date_add('day', -1, date_add('month', 1, date_trunc('month', date_add('month', (0 - shift_months), u.update_date_filled)))) AS DATE) END AS candidate_update_date,",
				                    "ROW_NUMBER() OVER (PARTITION BY u.task_row_id ORDER BY shift_months) AS candidate_rank",
				                    "FROM task_with_filled_update u",
				                    "CROSS JOIN UNNEST(SEQUENCE(0, CASE WHEN u.is_bl = TRUE AND u.update_date_filled IS NOT NULL THEN 240 ELSE 0 END)) AS s(shift_months)",
				                    "LEFT JOIN non_bl_dates nbd ON nbd.project_code = u.project_code AND nbd.programme_type = u.programme_type AND nbd.update_date = CASE WHEN u.update_date_filled IS NULL THEN NULL ELSE CAST(date_add('day', -1, date_add('month', 1, date_trunc('month', date_add('month', (0 - shift_months), u.update_date_filled)))) AS DATE) END",
				                    "WHERE u.is_bl = FALSE OR nbd.update_date IS NULL",
				                    "), task_base AS (",
				                    "SELECT u.status_code, u.task_code, u.total_float, u.task_type, u.id_name, u.early_start_date, u.calendar_id_key, u.task_id_key,",
				                    "u.driving_path_flag, u.remainingduration, u.early_end_date, u.monthupdate, u.task_name, u.data_date, u.act_end_date, u.finish,",
				                    "u.proj_id_key, u.wbs_id_key, u.free_float, u.cstr_type, u.start, u.filename, u.late_end_date, u.project_code, u.programme_type,",
				                    "c.candidate_update_date AS update_date,",
				                    "CASE WHEN u.status_code = 'Complete' THEN u.finish ELSE u.early_end_date END AS effective_early_end,",
				                    "CASE WHEN u.status_code = 'Complete' THEN u.finish ELSE u.late_end_date END AS effective_late_end",
				                    "FROM task_with_filled_update u",
				                    "LEFT JOIN update_candidates c ON c.task_row_id = u.task_row_id AND c.candidate_rank = 1",
				                    "), task_named AS (",
				                    "SELECT b.*,",
				                    "COALESCE(alt_project.""projectname"", orig_project.""projectname"") AS project_name,",
				                    "COALESCE(COALESCE(alt_project.""projectname"", orig_project.""projectname""), b.project_code) AS project_group_key",
				                    "FROM task_base b",
				                    "LEFT JOIN prod_projectcontrols_linkedsitereports.""dbo_project"" alt_project ON alt_project.""projectno"" = CASE WHEN b.project_code LIKE 'C%' THEN CONCAT('J', SUBSTR(b.project_code, 2)) ELSE b.project_code END",
				                    "LEFT JOIN prod_projectcontrols_linkedsitereports.""dbo_project"" orig_project ON orig_project.""projectno"" = b.project_code",
				                    "), task_snapshot AS (",
				                    "SELECT project_group_key, task_code, update_date,",
				                    "MAX(start) AS snapshot_start, MAX(finish) AS snapshot_finish, MAX(data_date) AS snapshot_data_date,",
				                    "MAX(remainingduration) AS snapshot_remainingduration, MAX(COALESCE(early_start_date, start)) AS snapshot_effective_start,",
				                    "MAX(COALESCE(early_end_date, finish)) AS snapshot_effective_finish,",
				                    "CASE WHEN COUNT(DISTINCT status_code) = 1 THEN MIN(status_code) ELSE NULL END AS snapshot_status",
				                    "FROM task_named",
				                    "GROUP BY project_group_key, task_code, update_date",
				                    "), task_snapshot_prev AS (",
				                    "SELECT project_group_key, task_code, update_date,",
				                    "LAG(update_date) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_update_date,",
				                    "LAG(snapshot_start) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_start,",
				                    "LAG(snapshot_finish) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_finish,",
				                    "LAG(snapshot_data_date) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_data_date,",
				                    "LAG(snapshot_remainingduration) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_remainingduration,",
				                    "LAG(snapshot_effective_start) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_effective_start,",
				                    "LAG(snapshot_effective_finish) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_effective_finish,",
				                    "LAG(snapshot_status) OVER (PARTITION BY project_group_key, task_code ORDER BY update_date) AS previous_task_status",
				                    "FROM task_snapshot",
				                    "), project_updates AS (",
				                    "SELECT DISTINCT project_group_key, update_date FROM task_named WHERE update_date IS NOT NULL",
				                    "), project_updates_prev AS (",
				                    "SELECT project_group_key, update_date, LAG(update_date) OVER (PARTITION BY project_group_key ORDER BY update_date) AS previous_project_update_date",
				                    "FROM project_updates",
				                    "), project_data_dates AS (",
				                    "SELECT DISTINCT project_group_key, data_date FROM task_named WHERE data_date IS NOT NULL",
				                    "), project_data_dates_prev AS (",
				                    "SELECT project_group_key, data_date, LAG(data_date) OVER (PARTITION BY project_group_key ORDER BY data_date) AS previous_data_date",
				                    "FROM project_data_dates",
				                    "), baseline_first_update AS (",
				                    "SELECT project_code, MIN(update_date) AS first_update_date FROM task_named GROUP BY project_code",
				                    "), baseline_lookup AS (",
				                    "SELECT n.project_code, n.task_code, MAX(n.start) AS baseline_start, MAX(n.finish) AS baseline_finish,",
				                    "MAX(n.effective_early_end) AS baseline_effective_early_end, MAX(n.effective_late_end) AS baseline_effective_late_end",
				                    "FROM task_named n",
				                    "INNER JOIN baseline_first_update b ON b.project_code = n.project_code AND b.first_update_date = n.update_date",
				                    "GROUP BY n.project_code, n.task_code",
				                    "), adjusted_first_month AS (",
				                    "SELECT project_code, task_code, MIN(monthupdate) AS first_added_month FROM task_named GROUP BY project_code, task_code",
				                    "), adjusted_lookup AS (",
				                    "SELECT n.project_code, n.task_code, f.first_added_month, MIN(n.start) AS adjusted_baseline_start, MAX(n.finish) AS adjusted_baseline_finish",
				                    "FROM task_named n",
				                    "INNER JOIN adjusted_first_month f ON f.project_code = n.project_code AND f.task_code = n.task_code AND f.first_added_month = n.monthupdate",
				                    "GROUP BY n.project_code, n.task_code, f.first_added_month",
				                    "), project_first_month AS (",
				                    "SELECT project_code, MIN(monthupdate) AS project_first_month FROM task_named GROUP BY project_code",
				                    "), task_joined AS (",
				                    "SELECT n.*, sp.previous_task_update_date, sp.previous_task_start, sp.previous_task_finish, sp.previous_task_data_date,",
				                    "sp.previous_task_remainingduration, sp.previous_task_effective_start, sp.previous_task_effective_finish, sp.previous_task_status,",
				                    "pu.previous_project_update_date, pps.snapshot_finish AS project_previous_task_finish, pps.snapshot_data_date AS project_previous_task_data_date,",
				                    "pps.snapshot_status AS project_previous_task_status, pdd.previous_data_date,",
				                    "bl.baseline_start, bl.baseline_finish, bl.baseline_effective_early_end, bl.baseline_effective_late_end,",
				                    "adj.adjusted_baseline_start, adj.adjusted_baseline_finish, adj.first_added_month, pfm.project_first_month",
				                    "FROM task_named n",
				                    "LEFT JOIN task_snapshot_prev sp ON sp.project_group_key = n.project_group_key AND sp.task_code = n.task_code AND sp.update_date = n.update_date",
				                    "LEFT JOIN project_updates_prev pu ON pu.project_group_key = n.project_group_key AND pu.update_date = n.update_date",
				                    "LEFT JOIN task_snapshot pps ON pps.project_group_key = n.project_group_key AND pps.task_code = n.task_code AND pps.update_date = pu.previous_project_update_date",
				                    "LEFT JOIN project_data_dates_prev pdd ON pdd.project_group_key = n.project_group_key AND pdd.data_date = n.data_date",
				                    "LEFT JOIN baseline_lookup bl ON bl.project_code = n.project_code AND bl.task_code = n.task_code",
				                    "LEFT JOIN adjusted_lookup adj ON adj.project_code = n.project_code AND adj.task_code = n.task_code",
				                    "LEFT JOIN project_first_month pfm ON pfm.project_code = n.project_code",
				                    "), network_inputs AS (",
				                    "SELECT *,",
				                    "CAST(previous_task_finish AS DATE) AS finish_var_start_date, CAST(finish AS DATE) AS finish_var_end_date,",
				                    "CAST(previous_task_start AS DATE) AS start_var_start_date, CAST(start AS DATE) AS start_var_end_date,",
				                    "CAST(baseline_finish AS DATE) AS baseline_var_start_date, CAST(finish AS DATE) AS baseline_var_end_date",
				                    "FROM task_joined",
				                    "), network_bounds AS (",
				                    "SELECT *,",
				                    "LEAST(finish_var_start_date, finish_var_end_date) AS finish_var_min_date, GREATEST(finish_var_start_date, finish_var_end_date) AS finish_var_max_date,",
				                    "LEAST(start_var_start_date, start_var_end_date) AS start_var_min_date, GREATEST(start_var_start_date, start_var_end_date) AS start_var_max_date,",
				                    "LEAST(baseline_var_start_date, baseline_var_end_date) AS baseline_var_min_date, GREATEST(baseline_var_start_date, baseline_var_end_date) AS baseline_var_max_date",
				                    "FROM network_inputs",
				                    "), network_parts AS (",
				                    "SELECT *,",
				                    "CASE WHEN finish_var_start_date IS NULL OR finish_var_end_date IS NULL THEN NULL ELSE date_diff('day', finish_var_min_date, finish_var_max_date) + 1 END AS finish_var_days,",
				                    "CASE WHEN start_var_start_date IS NULL OR start_var_end_date IS NULL THEN NULL ELSE date_diff('day', start_var_min_date, start_var_max_date) + 1 END AS start_var_days,",
				                    "CASE WHEN baseline_var_start_date IS NULL OR baseline_var_end_date IS NULL THEN NULL ELSE date_diff('day', baseline_var_min_date, baseline_var_max_date) + 1 END AS baseline_var_days",
				                    "FROM network_bounds",
				                    "), network_calcs AS (",
				                    "SELECT *,",
				                    "CAST(FLOOR(finish_var_days / 7.0) AS INTEGER) AS finish_var_full_weeks, CAST(MOD(finish_var_days, 7) AS INTEGER) AS finish_var_remainder, day_of_week(finish_var_min_date) AS finish_var_dow,",
				                    "CAST(FLOOR(start_var_days / 7.0) AS INTEGER) AS start_var_full_weeks, CAST(MOD(start_var_days, 7) AS INTEGER) AS start_var_remainder, day_of_week(start_var_min_date) AS start_var_dow,",
				                    "CAST(FLOOR(baseline_var_days / 7.0) AS INTEGER) AS baseline_var_full_weeks, CAST(MOD(baseline_var_days, 7) AS INTEGER) AS baseline_var_remainder, day_of_week(baseline_var_min_date) AS baseline_var_dow",
				                    "FROM network_parts",
				                    ")",
				                    "SELECT status_code, task_code, total_float, task_type, id_name, early_start_date, calendar_id_key, task_id_key, driving_path_flag, remainingduration,",
				                    "early_end_date, monthupdate, task_name, data_date, act_end_date, finish, proj_id_key, wbs_id_key, free_float, cstr_type, start, filename, late_end_date,",
				                    "project_code AS ""ProjectCode"", update_date AS ""UpdateDate"", project_name AS ""ProjectName"",",
				                    "CASE WHEN finish_var_start_date IS NULL OR finish_var_end_date IS NULL THEN 0 WHEN finish_var_start_date = finish_var_end_date THEN 0 ELSE (CASE WHEN finish_var_end_date >= finish_var_start_date THEN 1 ELSE -1 END) * (finish_var_full_weeks * 5 + GREATEST(0, LEAST(finish_var_remainder, 6 - finish_var_dow)) + GREATEST(0, finish_var_remainder - (8 - finish_var_dow))) END AS ""Finish_Variance_Previous_Month"",",
				                    "CASE WHEN NOT (task_type IN ('TT_Task', 'TT_Rsrc', 'TT_Mile', 'TT_FinMile') AND task_code IS NOT NULL AND project_name IS NOT NULL AND COALESCE(status_code, '') <> 'Complete' AND data_date IS NOT NULL AND update_date IS NOT NULL) THEN 'Not Driven' WHEN status_code = 'Not Started' AND previous_task_update_date IS NOT NULL AND previous_task_data_date IS NOT NULL AND previous_task_status = 'Not Started' AND date_diff('day', CAST(previous_task_data_date AS DATE), CAST(data_date AS DATE)) > 0 AND date_diff('day', CAST(previous_task_effective_start AS DATE), CAST(COALESCE(early_start_date, start) AS DATE)) > 0 AND ABS(date_diff('day', CAST(previous_task_effective_start AS DATE), CAST(COALESCE(early_start_date, start) AS DATE)) - date_diff('day', CAST(previous_task_data_date AS DATE), CAST(data_date AS DATE))) <= 1 AND COALESCE(early_start_date, start) IS NOT NULL AND COALESCE(early_end_date, finish) IS NOT NULL AND previous_task_effective_start IS NOT NULL AND previous_task_effective_finish IS NOT NULL AND ABS(date_diff('day', CAST(COALESCE(early_start_date, start) AS DATE), CAST(COALESCE(early_end_date, finish) AS DATE)) - date_diff('day', CAST(previous_task_effective_start AS DATE), CAST(previous_task_effective_finish AS DATE))) <= 1 THEN 'Not Started - Slippage Matches Update Period' WHEN status_code = 'In Progress' AND previous_task_update_date IS NOT NULL AND previous_task_data_date IS NOT NULL AND previous_task_status = 'In Progress' AND date_diff('day', CAST(previous_task_data_date AS DATE), CAST(data_date AS DATE)) > 0 AND remainingduration IS NOT NULL AND previous_task_remainingduration IS NOT NULL AND remainingduration >= previous_task_remainingduration - 1 AND date_diff('day', CAST(previous_task_effective_finish AS DATE), CAST(COALESCE(early_end_date, finish) AS DATE)) > 0 AND ABS(date_diff('day', CAST(previous_task_effective_finish AS DATE), CAST(COALESCE(early_end_date, finish) AS DATE)) - date_diff('day', CAST(previous_task_data_date AS DATE), CAST(data_date AS DATE))) <= 1 THEN 'In Progress - Stagnating Progress' WHEN status_code = 'Not Started' AND COALESCE(early_start_date, start) IS NOT NULL AND CAST(COALESCE(early_start_date, start) AS DATE) = CAST(data_date AS DATE) THEN 'Not Started - Early Start Sitting on Data Date' WHEN status_code = 'In Progress' AND early_start_date IS NOT NULL AND remainingduration IS NOT NULL AND remainingduration > 0 AND CAST(COALESCE(early_start_date, start) AS DATE) = CAST(data_date AS DATE) THEN 'In Progress - Remaining Work Sitting on Data Date' ELSE 'Not Driven' END AS ""Driven_DataDate"",",
				                    "CASE WHEN baseline_var_start_date IS NULL OR baseline_var_end_date IS NULL THEN NULL WHEN baseline_var_start_date = baseline_var_end_date THEN 0 ELSE (CASE WHEN baseline_var_end_date >= baseline_var_start_date THEN 1 ELSE -1 END) * (baseline_var_full_weeks * 5 + GREATEST(0, LEAST(baseline_var_remainder, 6 - baseline_var_dow)) + GREATEST(0, baseline_var_remainder - (8 - baseline_var_dow))) END AS ""Variance_Finish_BL"",",
				                    "baseline_finish AS ""Baseline Finish"", baseline_start AS ""Baseline Start"", COALESCE(previous_task_start, start) AS ""Previous Month Start"", COALESCE(previous_task_finish, finish) AS ""Previous Month Finish"",",
				                    "CASE WHEN previous_project_update_date IS NOT NULL AND project_previous_task_finish > project_previous_task_data_date AND project_previous_task_finish <= data_date AND COALESCE(status_code, '') <> 'Complete' THEN 1 ELSE 0 END AS ""Planned Not Completed Last Period"",",
				                    "CASE WHEN start_var_start_date IS NULL OR start_var_end_date IS NULL THEN 0 WHEN start_var_start_date = start_var_end_date THEN 0 ELSE (CASE WHEN start_var_end_date >= start_var_start_date THEN 1 ELSE -1 END) * (start_var_full_weeks * 5 + GREATEST(0, LEAST(start_var_remainder, 6 - start_var_dow)) + GREATEST(0, start_var_remainder - (8 - start_var_dow))) END AS ""Start_Variance_Previous_Month"",",
				                    "previous_data_date AS ""PreviousDataDate"", previous_task_remainingduration AS ""Previous Remaining Working Days"",",
				                    "CASE WHEN previous_project_update_date IS NOT NULL AND project_previous_task_finish > project_previous_task_data_date AND project_previous_task_finish <= data_date THEN 1 ELSE 0 END AS ""Planned Last Period"",",
				                    "CASE WHEN status_code = 'Complete' AND project_previous_task_status <> 'Complete' AND project_previous_task_status IS NOT NULL THEN 1 ELSE 0 END AS ""Completed Last Period"",",
				                    "CASE WHEN previous_project_update_date IS NOT NULL AND project_previous_task_finish > project_previous_task_data_date AND project_previous_task_finish <= data_date AND status_code = 'Complete' THEN 1 ELSE 0 END AS ""Completed of Planned Last Period"",",
				                    "baseline_effective_early_end AS ""Baseline Effective_Early_End"", baseline_effective_late_end AS ""Baseline Effective_Late_End"",",
				                    "adjusted_baseline_finish AS ""Adjusted Baseline Finish"", adjusted_baseline_start AS ""Adjusted Baseline Start"", first_added_month AS ""Adjusted Baseline Source Month"",",
				                    "CASE WHEN first_added_month IS NULL THEN NULL WHEN project_first_month IS NULL THEN 'Unknown' WHEN first_added_month = project_first_month THEN 'Original Baseline' WHEN first_added_month > project_first_month THEN 'Later Update' ELSE 'Unknown' END AS ""Adjusted Baseline Source""",
				                    "FROM network_calcs"
				                },
				                " "
				            ),
				            null
				        ),
				
				    Typed =
				        Table.TransformColumnTypes(
				            SourceRaw,
				            {
				                {"act_end_date", type datetime},
				                {"UpdateDate", type date},
				                {"early_start_date", type datetime},
				                {"early_end_date", type datetime},
				                {"late_end_date", type datetime},
				                {"start", type datetime},
				                {"finish", type datetime},
				                {"data_date", type datetime},
				                {"monthupdate", type date},
				                {"total_float", type number},
				                {"free_float", type number},
				                {"remainingduration", type number},
				                {"Finish_Variance_Previous_Month", Int64.Type},
				                {"Variance_Finish_BL", Int64.Type},
				                {"Baseline Finish", type datetime},
				                {"Baseline Start", type datetime},
				                {"Previous Month Start", type datetime},
				                {"Previous Month Finish", type datetime},
				                {"Planned Not Completed Last Period", Int64.Type},
				                {"Start_Variance_Previous_Month", Int64.Type},
				                {"PreviousDataDate", type datetime},
				                {"Previous Remaining Working Days", type number},
				                {"Planned Last Period", Int64.Type},
				                {"Completed Last Period", Int64.Type},
				                {"Completed of Planned Last Period", Int64.Type},
				                {"Baseline Effective_Early_End", type datetime},
				                {"Baseline Effective_Late_End", type datetime},
				                {"Adjusted Baseline Finish", type datetime},
				                {"Adjusted Baseline Start", type datetime},
				                {"Adjusted Baseline Source Month", type datetime}
				            }
				        ),
				
				    Renamed =
				        Table.RenameColumns(
				            Typed,
				            {
				                {"start", "Start"},
				                {"finish", "Finish"},
