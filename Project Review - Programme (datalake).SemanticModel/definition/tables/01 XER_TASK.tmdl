	column CriticalStatus = ```
			
			VAR TaskStatus = TRIM(UPPER('01 XER_TASK'[status_code]))
			VAR FloatValue = '01 XER_TASK'[total_float]
			RETURN
			    IF(
			        TaskStatus <> "COMPLETE",
			        SWITCH(
			            TRUE(),
			            FloatValue <= 0, "Critical",
			            FloatValue > 0 && FloatValue <= 10, "Near Critical",
			            "Non-Critical"
			        ),
			        BLANK()
			    )
			
			```
		lineageTag: d8c504df-6a4d-49ad-9b83-1c8b123677b6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column FinishDateCategory = ```
			
			IF(
			   '01 XER_TASK'[status_code] <> "Complete",
			    VAR StartDate = '01 XER_TASK'[Finish]
			    VAR DataDate = '01 XER_TASK'[data_date]
			    VAR MonthsDifference = 
			        DATEDIFF(DataDate, StartDate, MONTH) + 
			        IF(DAY(StartDate) < DAY(DataDate), -1, 0)
			    RETURN
			        SWITCH(
			            TRUE(),
			            StartDate < DataDate, "Outside Range",
			            MonthsDifference < 1, " <1 Month",
			            MonthsDifference >= 1 && MonthsDifference < 3, " 1-3 Months",
			            MonthsDifference >= 3 && MonthsDifference < 6, " 3-6 Months",
			            MonthsDifference >= 6, ">6 Months",
			            BLANK()
			        ),
			    BLANK()
			)
			
			```
		lineageTag: b634f4d2-0ad4-4833-b622-257f56d60210
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column StartDateCategory = ```
			
			IF(
			    // Only proceed if task_type is "TT_Task" and Activity_Status is "Not Started"
			   '01 XER_TASK'[status_code] = "Not Started",
			    
			    // Define variables
			    VAR StartDate = '01 XER_TASK'[Start]
			    VAR DataDate = '01 XER_TASK'[data_date]
			    VAR MonthsDifference = 
			        DATEDIFF(DataDate, StartDate, MONTH) + 
			        IF(DAY(StartDate) < DAY(DataDate), -1, 0)
			    
			    // Return the category based on MonthsDifference
			    RETURN
			        SWITCH(
			            TRUE(),
			            StartDate < DataDate, "Outside Range",
			            MonthsDifference < 1, " <1 Month",
			            MonthsDifference >= 1 && MonthsDifference < 3, " 1-3 Months",
			            MonthsDifference >= 3 && MonthsDifference < 6, " 3-6 Months",
			            MonthsDifference >= 6, ">6 Months",
			            BLANK()
			        ),
			    
			    // If conditions are not met, return BLANK()
			    BLANK()
			)
			```
		lineageTag: b718f299-5eee-4a98-9cc9-369593fb4096
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Finish_Variance_Previous_Month = ```
			
			VAR CurrentTaskCode = '01 XER_TASK'[task_code]
			VAR CurrentProjectName = '01 XER_TASK'[ProjectName]
			VAR CurrentMonthUpdate = '01 XER_TASK'[UpdateDate]
			VAR CurrentFinishDate = '01 XER_TASK'[Finish]
			
			VAR PreviousMonthUpdate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        FILTER(
			            '01 XER_TASK',
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectName] = CurrentProjectName &&
			            '01 XER_TASK'[UpdateDate] < CurrentMonthUpdate
			        )
			    )
			
			VAR PreviousFinishDate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[Finish]),
			        FILTER(
			            '01 XER_TASK',
			            '01 XER_TASK'[task_code] = CurrentTaskCode &&
			            '01 XER_TASK'[ProjectName] = CurrentProjectName &&
			            '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate
			        )
			    )
			
			RETURN
			    IF(
			        NOT(ISBLANK(PreviousFinishDate)) &&
			        NOT(ISBLANK(CurrentFinishDate)),
			        IF(
			            PreviousFinishDate = CurrentFinishDate,
			            0,
			            NETWORKDAYS(PreviousFinishDate, CurrentFinishDate)
			        ),
			        0
			    )
			```
		formatString: 0
		lineageTag: 40bdc0d3-a016-4c81-a60a-154fdd803918
		summarizeBy: none

		annotation SummarizationSetBy = User

	column 'No Predecessor' = if(CALCULATE(COUNTA('06 XER_PREDECESSOR'[pred_task_id_key]))=BLANK(),1,0)
		formatString: 0
		lineageTag: a09ffef3-83b6-400e-bfcb-d129f64a7cdd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Driven_DataDate = ```
			
			VAR CurrentDataDate = '01 XER_TASK'[data_date]
			VAR PreviousDataDate = '01 XER_TASK'[PreviousDataDate]
			
			-- Extract date-only portions
			VAR CurrentDataDateOnly = DATE(YEAR(CurrentDataDate), MONTH(CurrentDataDate), DAY(CurrentDataDate))
			VAR TaskStartDateOnly = DATE(YEAR('01 XER_TASK'[Start]), MONTH('01 XER_TASK'[Start]), DAY('01 XER_TASK'[Start]))
			VAR TaskFinishDateOnly = DATE(YEAR('01 XER_TASK'[Finish]), MONTH('01 XER_TASK'[Finish]), DAY('01 XER_TASK'[Finish]))
			
			-- Calculate Date Gaps (Positive = Future, Negative = Past)
			VAR StartGap = DATEDIFF(CurrentDataDateOnly, TaskStartDateOnly, DAY)
			VAR FinishGap = DATEDIFF(CurrentDataDateOnly, TaskFinishDateOnly, DAY)
			
			VAR UpdatePeriod = 
			    IF(
			        NOT(ISBLANK(PreviousDataDate)),
			        DATEDIFF(PreviousDataDate, CurrentDataDate, DAY),
			        0
			    )
			
			VAR TaskStartSlippage = 
			    IF(
			        NOT(ISBLANK('01 XER_TASK'[Previous Month Start])),
			        DATEDIFF('01 XER_TASK'[Previous Month Start], '01 XER_TASK'[Start], DAY),
			        0
			    )
			
			VAR CurrentDuration = DATEDIFF('01 XER_TASK'[Start], '01 XER_TASK'[Finish], DAY)
			VAR PreviousDuration = 
			    IF(
			        NOT(ISBLANK('01 XER_TASK'[Previous Month Finish])) && NOT(ISBLANK('01 XER_TASK'[Previous Month Start])),
			        DATEDIFF('01 XER_TASK'[Previous Month Start], '01 XER_TASK'[Previous Month Finish], DAY),
			        BLANK()
			    )
			
			RETURN
			SWITCH( TRUE(),
			
			    -- 1. IN PROGRESS STAGNATION (Behavioral)
			    -- Highest priority: Identifies work that is "riding" the line because updates stopped.
			    ('01 XER_TASK'[status_code] = "In Progress"
			        && UpdatePeriod > 0
			        && NOT(ISBLANK('01 XER_TASK'[Previous Remaining Working Days]))
			        && '01 XER_TASK'[remaining_duration] >= ('01 XER_TASK'[Previous Remaining Working Days] - 1) 
			    ), "Stagnating Progress",
			
			    -- 2. TRUE SLIPPAGE (Behavioral)
			    -- Second priority: Identifies unstarted work that shifted exactly with the update cycle.
			    ('01 XER_TASK'[status_code] = "Not Started"
			        && UpdatePeriod > 0
			        && TaskStartSlippage > 0 
			        && ABS(TaskStartSlippage - UpdatePeriod) <= 1  
			        && ABS(CurrentDuration - PreviousDuration) <= 1 
			    ), "Slippage Matches Update Period",
			
			    -- 3. PAST DUE START (Hygiene)
			    -- Task should have started but hasn't.
			    ('01 XER_TASK'[status_code] = "Not Started" && TaskStartDateOnly < CurrentDataDateOnly),
			    "Start Date in Past",
			
			    -- 4. OVERDUE FINISH (Hygiene)
			    -- Task is In Progress but the finish date is in the past.
			    ('01 XER_TASK'[status_code] = "In Progress" && TaskFinishDateOnly <= CurrentDataDateOnly),
			    "Finish Date in Past",
			
			    -- 5. PROXIMITY CHECK (Positional)
			    -- Generic check: Is the Start or Finish within 0-3 days of the Data Date?
			    -- This catches tasks validly scheduled 'now' or on the immediate horizon.
			    (StartGap >= 0 && StartGap <= 3), "Scheduled Start Near Data Date",
			    
			    (FinishGap >= 0 && FinishGap <= 3), "Scheduled Finish Near Data Date",
			    
			    -- DEFAULT
			    "Not Driven"
			)
			```
		lineageTag: 94225685-becc-4744-a625-f9973e146094
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

