	column Level_2 =
			
			VAR WBS4_Name = LOOKUPVALUE(
			    '03 XER_PROJWBS'[wbs_name],
			    '03 XER_PROJWBS'[wbs_id_key],
			    PATHITEM('03 XER_PROJWBS'[Path], 2)
			)
			RETURN
			    COALESCE(WBS4_Name, '03 XER_PROJWBS'[Level_1])
