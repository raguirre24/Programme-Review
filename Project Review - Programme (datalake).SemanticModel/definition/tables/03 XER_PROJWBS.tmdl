	column ProjectCode
		dataType: string
		lineageTag: 5a0c250b-75e8-481f-8458-7fd22b012dad
		summarizeBy: none
		sourceColumn: ProjectCode

		annotation SummarizationSetBy = Automatic

	column ProjectName = LOOKUPVALUE('01 XER_TASK'[ProjectName],'01 XER_TASK'[ProjectCode],'03 XER_PROJWBS'[ProjectCode])
		lineageTag: 3ee2cfee-4d02-411a-9833-4f75fc51028c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition '03 XER_PROJWBS' = m
		mode: import
		queryGroup: XER
		source =
				let
				    Source = fnAthenaSource("03_xer_projwbs"),
				
				    SelectedColumns =
				        Table.SelectColumns(
				            Source,
				            {
				                "wbs_name",
				                "wbs_id_key",
				                "parent_wbs_id_key",
				                "filename"
				            }
				        ),
				
				    AddProjectCode =
				        Table.AddColumn(
				            SelectedColumns,
				            "ProjectCode",
				            each
				                if [filename] <> null and Text.Contains([filename], "-") then
				                    Text.BeforeDelimiter([filename], "-")
				                else
				                    null,
				            type nullable text
				        ),
				
				    CleanParentWBS =
				        Table.TransformColumns(
				            AddProjectCode,
				            {
				                {
				                    "parent_wbs_id_key",
				                    each if _ = "" then null else _,
				                    type nullable text
				                }
				            }
				        ),
				
				    Final =
				        Table.SelectColumns(
				            CleanParentWBS,
				            {
				                "wbs_name",
				                "wbs_id_key",
				                "parent_wbs_id_key",
				                "ProjectCode"
				            }
				        )
				in
				    Final

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

