table 'Monthly Resource Distribution Baseline'
	lineageTag: fa1cf293-638c-4a26-8dd7-9b7d1bbee83f

	column distribution_month
		formatString: General Date
		lineageTag: 91060a6f-a529-4484-a660-a45fc726a5bc
		summarizeBy: none
		isNameInferred
		sourceColumn: 15_XER_RESOURCE_DISTRIBUTION[distribution_month]

		annotation SummarizationSetBy = Automatic

	column ProjectCode
		lineageTag: 35f544e4-02c3-41c6-aab9-dd9cf7e29c83
		summarizeBy: none
		isNameInferred
		sourceColumn: 15_XER_RESOURCE_DISTRIBUTION[ProjectCode]

		annotation SummarizationSetBy = Automatic

	column monthly_hours
		formatString: #,0.00
		lineageTag: e3f4a5b6-c7d8-9012-3456-789abcdef012
		summarizeBy: sum
		isNameInferred
		sourceColumn: 15_XER_RESOURCE_DISTRIBUTION[monthly_hours]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	partition 'Monthly Resource Distribution Baseline' = calculated
		mode: import
		source =
				
				SELECTCOLUMNS(
				    FILTER(
				        '15_XER_RESOURCE_DISTRIBUTION',
				        '15_XER_RESOURCE_DISTRIBUTION'[task_id_key] IN VALUES('04 XER_BASELINE'[task_id_key])
				    ),
				    "distribution_month", '15_XER_RESOURCE_DISTRIBUTION'[distribution_month],
				    "ProjectCode", '15_XER_RESOURCE_DISTRIBUTION'[ProjectCode],
				    "monthly_hours", '15_XER_RESOURCE_DISTRIBUTION'[monthly_hours]
				)

	annotation PBI_Id = e8e5aed95e8c4576a9cdbf22ecc98dbc

