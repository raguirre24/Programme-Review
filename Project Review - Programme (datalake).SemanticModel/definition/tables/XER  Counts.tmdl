	measure Count_Tasks_Continuous = ```
			
			VAR CurrentCount = COUNTROWS('01 XER_TASK')
			
			VAR Level2_IsActiveInMonth = 
			    CALCULATE(
			        NOT ISEMPTY('01 XER_TASK'),
			        ALL('01 XER_TASK'[PreviousMonthFinishVarianceCategory])
			    )
			
			RETURN
			
			    IF(
			        Level2_IsActiveInMonth,
			        COALESCE(CurrentCount, 0),
			        BLANK()
			    )
			```
		formatString: 0
		lineageTag: c7647c7a-0d79-49e7-8fbb-f6a59d2a8945

