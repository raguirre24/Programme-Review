	measure PreviousMonth_StartVariance_Ahead_TT_Task = ```
			
			VAR CountResult = 
			    CALCULATE(
			        COUNTROWS('01 XER_TASK'),
			        '01 XER_TASK'[PreviousMonthStartVarianceCategory] = "  Ahead"
			    )
			RETURN
			    IF(
			        ISBLANK(MIN('01 XER_TASK'[UpdateDate])),
			        BLANK(),
			        COALESCE(CountResult, 0)
			    )
			```
		formatString: #,0
		displayFolder: Previous Month Start Variance
		lineageTag: 3cd5f7e1-b314-48ff-9281-42abb21b133b

