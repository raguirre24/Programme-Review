	measure 'As Late' =
			
			VAR _ProjectHasActivity =
			    COUNTROWS ( '01 XER_TASK' )
			RETURN
			    IF (
			        _ProjectHasActivity > 0,
			        CALCULATE (
			            COUNTROWS ( '01 XER_TASK' ),
			            '01 XER_TASK'[cstr_type] = "CS_ALAP",
			            '01 XER_TASK'[status_code] <> "Complete"
			        ) + 0
			    )
		formatString: 0
		displayFolder: Constraint Count
		lineageTag: 565c7398-9732-4289-9bb9-749706eed4dc

