	measure Count_Incomplete_Float_0_to_10 =
			
			VAR _ProjectHasActivity =
			    COUNTROWS ( '01 XER_TASK' )
			RETURN
			    IF (
			        _ProjectHasActivity > 0,
			        CALCULATE (
			            COUNTROWS ( '01 XER_TASK' ),
			            '01 XER_TASK'[status_code] <> "Complete",
			            '01 XER_TASK'[total_float] >= 0,
			            '01 XER_TASK'[total_float] <= 10
			        ) + 0
			    )
		formatString: #,0
		displayFolder: Float Analysis
		lineageTag: 88f7bc8b-7b45-4ab9-bc77-74e9e5623682

