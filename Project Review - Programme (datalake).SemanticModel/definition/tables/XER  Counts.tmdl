	measure Count_Critical_Tasks = ```
			
			VAR CountResult = 
			    CALCULATE(
			        COUNTROWS('01 XER_TASK'),
			        '01 XER_TASK'[CriticalStatus] = "Critical"
			    )
			RETURN
			    IF(
			        ISBLANK(MIN('01 XER_TASK'[UpdateDate])),
			        BLANK(),
			        COALESCE(CountResult, 0)
			    )
			```
		formatString: #,0
		displayFolder: Critical Status
		lineageTag: ec6e65b2-d186-494a-95dc-3c25cdd6f03d

