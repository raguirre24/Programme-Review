	measure Percentage_Cumulative_Actual_Finish = ```
			
			VAR MaxDataDate = MAX('01 XER_TASK'[data_date])
			VAR CurrentMonth = MAX('00 CALENDAR'[Date])
			
			// Extract year and month components for comparison
			VAR CurrentYearMonth = YEAR(CurrentMonth) * 100 + MONTH(CurrentMonth)
			VAR MaxDataYearMonth = YEAR(MaxDataDate) * 100 + MONTH(MaxDataDate)
			
			VAR AllMonthsUpToCurrent = 
			    FILTER(
			        ALL('00 CALENDAR'[Date]),
			        '00 CALENDAR'[Date] <= CurrentMonth
			    )
			
			// 1. Calculate the Numerator (Cumulative Finished Tasks)
			VAR CumulativeFinishedCount = 
			    CALCULATE(
			        COUNTA('01 XER_TASK'[act_end_date]),
			        USERELATIONSHIP('01 XER_TASK'[act_end_date], '00 CALENDAR'[Date]),
			        AllMonthsUpToCurrent
			    )
			
			// 2. Calculate the Denominator (Total Scope of Tasks)
			// We remove filters from the Calendar table to get the total count for the whole project
			VAR TotalProjectTasks = 
			    CALCULATE(
			        COUNTROWS('01 XER_TASK'),
			        ALL('00 CALENDAR') 
			    )
			
			RETURN
			IF(
			    CurrentYearMonth <= MaxDataYearMonth, 
			    DIVIDE(CumulativeFinishedCount, TotalProjectTasks, 0),
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Overall Progress %
		lineageTag: 57830d6b-565b-44d5-a6e1-b81b5b9edf9a

