	measure Percentage_Baseline_Finish = ```
			
			VAR MaxDataDate =
			    MAX( '01 XER_TASK'[data_date] )
			
			VAR CompletedCount =
			    CALCULATE(
			        COUNTROWS( '01 XER_TASK' ),
			        '01 XER_TASK'[Baseline Effective_Early_End] <= MaxDataDate,
			        NOT( ISBLANK( '01 XER_TASK'[Baseline Effective_Early_End] ) )
			    )
			
			VAR TotalCount =
			    CALCULATE(
			        COUNTROWS( '01 XER_TASK' ),
			        NOT( ISBLANK( '01 XER_TASK'[Baseline Effective_Early_End] ))
			    )
			
			VAR PercentageResult =
			    DIVIDE( CompletedCount, TotalCount, 0 )
			
			RETURN
			    PercentageResult
			
			```
