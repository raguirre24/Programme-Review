	measure Percentage_Actual_Finish = ```
			
			VAR MaxDataDate =
			    MAX( '01 XER_TASK'[data_date] )
			
			VAR CompletedCount =
			    CALCULATE(
			        COUNTROWS( '01 XER_TASK' ),
			        '01 XER_TASK'[act_end_date] <= MaxDataDate,
			        NOT( ISBLANK( '01 XER_TASK'[act_end_date] ) )
			    )
			
			VAR TotalCount =
			    CALCULATE(
			        COUNTROWS( '01 XER_TASK' )
			    )
			
			VAR PercentageResult =
			    DIVIDE( CompletedCount, TotalCount, 0 )
			
			RETURN
			 PercentageResult
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 48e5ddd3-9faf-4e20-ad96-ec006cf7f39c

