	measure Cumulative_Count_Finish_TT_Task = ```
			
			CALCULATE(
			    COUNTROWS('01 XER_TASK'),
			    FILTER(
			        ALLSELECTED('01 XER_TASK'),
			        '01 XER_TASK'[Finish] <= MAX('01 XER_TASK'[Finish])
			    )
			)
			
			```
		formatString: #,0
		displayFolder: Activity Completion
		lineageTag: 43d431e6-5fae-47ef-a42f-e574cd79eae0

	measure Cumulative_Count_Actual_Finish = ```
			
			VAR MaxDataDate = MAX('01 XER_TASK'[data_date])
			VAR CurrentMonth = MAX('00 CALENDAR'[Date])
			
			// Extract year and month components for comparison
			VAR CurrentYearMonth = YEAR(CurrentMonth) * 100 + MONTH(CurrentMonth)
			VAR MaxDataYearMonth = YEAR(MaxDataDate) * 100 + MONTH(MaxDataDate)
			
			VAR LastDateInCurrentMonth = 
			    CALCULATE(
			        MAX('00 CALENDAR'[Date]),
			        '00 CALENDAR'[Date] = CurrentMonth
			    )
			VAR AllMonthsUpToCurrent = 
			    FILTER(
			        ALL('00 CALENDAR'[Date]),
			        '00 CALENDAR'[Date] <= CurrentMonth
			    )
			RETURN
			IF(
			    CurrentYearMonth <= MaxDataYearMonth, // Compare year-month values instead of dates
			    CALCULATE(
			        COUNTA('01 XER_TASK'[act_end_date]),
			        USERELATIONSHIP('01 XER_TASK'[act_end_date], '00 CALENDAR'[Date]),
			        AllMonthsUpToCurrent
			    ),
			    BLANK()
			)
			```
		formatString: #,0
		displayFolder: Overall Progress Count
		lineageTag: d3381464-a2b8-4f18-a0d2-35300e48a1d3

	measure Cumulative_Count_BL_Finish_TT_Task =
			
			CALCULATE(
			    COUNTA('04 XER_BASELINE'[Finish]),
			    REMOVEFILTERS(CurrentDate[UpdateDate]),
			    USERELATIONSHIP(
			        '04 XER_BASELINE'[Finish],
			        '00 CALENDAR'[Date]
			    ),
			    FILTER(
			        ALLSELECTED('00 CALENDAR'[Date]),
			        ISONORAFTER('00 CALENDAR'[Date], MAX('00 CALENDAR'[Date]), DESC)
			    )
			)
		formatString: 0
		displayFolder: Activity Completion
		lineageTag: 5bc5298d-2805-4698-953a-8775d1e8edf1

