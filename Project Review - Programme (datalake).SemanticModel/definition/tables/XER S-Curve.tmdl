	measure Count_Remaining_Tasks_ = ```
			
			VAR MaxDataDate = MAX('01 XER_TASK'[data_date])
			VAR RemainingTasks = 
			    CALCULATE(
			        COUNTROWS('01 XER_TASK'),
			        FILTER(
			            '01 XER_TASK',
			            ISBLANK('01 XER_TASK'[act_end_date]) || '01 XER_TASK'[act_end_date] > MaxDataDate
			        ),
			        ALL('00 CALENDAR')
			    )
			RETURN
			    RemainingTasks
			```
