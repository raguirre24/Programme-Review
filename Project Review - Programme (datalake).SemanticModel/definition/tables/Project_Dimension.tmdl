	column ProjectId
		formatString: 0
		lineageTag: ea353b97-1a97-4a4b-97a9-0017737f893d
		summarizeBy: none
		isNameInferred
		sourceColumn: [ProjectId]

		annotation SummarizationSetBy = Automatic

	partition Project_Dimension = calculated
		mode: import
		source =
				
				VAR BaseProjects =
				    DISTINCT(
				        SELECTCOLUMNS(
				            FILTER(
				                ALL('01 XER_TASK'),
				                '01 XER_TASK'[wbs_id_key] <> BLANK()
				                    && '01 XER_TASK'[ProjectName] <> BLANK()
				            ),
				            "Project", '01 XER_TASK'[ProjectName],
				            "wbs_id_key", '01 XER_TASK'[wbs_id_key],
				            "ProjectCode", '01 XER_TASK'[ProjectCode]
				        )
				    )
				VAR WithAltProjectCode =
				    ADDCOLUMNS(
				        BaseProjects,
				        "AltProjectCode",
				            SWITCH(
				                TRUE(),
				                UPPER(LEFT([ProjectCode], 1)) = "C", "J" & MID([ProjectCode], 2, LEN([ProjectCode]) - 1),
				                UPPER(LEFT([ProjectCode], 1)) = "J", "C" & MID([ProjectCode], 2, LEN([ProjectCode]) - 1),
				                BLANK()
				            )
				    )
				VAR WithProjectMetadata =
				    ADDCOLUMNS(
				        WithAltProjectCode,
				        "State",
				            VAR OriginalState =
				                LOOKUPVALUE(
				                    'dbo_project'[state],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalState),
				                    OriginalState,
				                    LOOKUPVALUE(
				                        'dbo_project'[state],
				                        'dbo_project'[projectno], [AltProjectCode]
				                    )
				                ),
				        "CompanyId",
				            VAR OriginalCompanyId =
				                LOOKUPVALUE(
				                    'dbo_project'[companyid],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalCompanyId),
				                    OriginalCompanyId,
				                    LOOKUPVALUE(
				                        'dbo_project'[companyid],
				                        'dbo_project'[projectno], [AltProjectCode]
				                    )
				                ),
				        "ProjectId",
				            VAR OriginalProjectId =
				                LOOKUPVALUE(
				                    'dbo_project'[projectid],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalProjectId),
				                    OriginalProjectId,
				                    LOOKUPVALUE(
				                        'dbo_project'[projectid],
				                        'dbo_project'[projectno], [AltProjectCode]
				                    )
				                ),
				        "Level_2",
				            LOOKUPVALUE(
				                '03 XER_PROJWBS'[Level_2],
				                '03 XER_PROJWBS'[wbs_id_key], [wbs_id_key]
				            ),
				        "Level_3",
				            LOOKUPVALUE(
				                '03 XER_PROJWBS'[Level_3],
				                '03 XER_PROJWBS'[wbs_id_key], [wbs_id_key]
				            ),
				        "Level_4",
				            LOOKUPVALUE(
				                '03 XER_PROJWBS'[Level_4],
				                '03 XER_PROJWBS'[wbs_id_key], [wbs_id_key]
				            )
				    )
				RETURN
				    SELECTCOLUMNS(
				        WithProjectMetadata,
				        "Project", [Project],
				        "wbs_id_key", [wbs_id_key],
				        "State", [State],
				        "Level_2", [Level_2],
				        "Level_3", [Level_3],
				        "Level_4", [Level_4],
				        "ProjectCode", [ProjectCode],
				        "CompanyId", [CompanyId],
				        "ProjectId", [ProjectId]
				)

	annotation PBI_Id = 50f5c4a91ce0444bb70d1e41ee30c977

