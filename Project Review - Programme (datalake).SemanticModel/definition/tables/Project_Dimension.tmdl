table Project_Dimension
	lineageTag: b6b57912-cd01-4aa2-a5f1-73da79d32e2a

	measure 'Project Has Data' = ```
			
			IF(
			    NOT ISEMPTY('01 XER_TASK'),
			    "#28a745", 
			    "#6c757d"
			)
			```
		lineageTag: c1f0e01a-22cf-4068-92ca-1f50216612fc

	column Project
		lineageTag: 5538cb53-68b7-49a0-a8e2-9e118e2a3e9e
		summarizeBy: none
		isNameInferred
		sourceColumn: [Project]

		annotation SummarizationSetBy = Automatic

