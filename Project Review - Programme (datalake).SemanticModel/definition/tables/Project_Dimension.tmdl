	column ProjectCode
		lineageTag: 8c536fcc-4f90-45d3-82c3-5aeb6894f4f5
		summarizeBy: none
		isNameInferred
		sourceColumn: [ProjectCode]

		annotation SummarizationSetBy = Automatic

	partition Project_Dimension = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    DISTINCT(
				        SELECTCOLUMNS(
				            FILTER(
				                ALL('01 XER_TASK'),
				                '01 XER_TASK'[wbs_id_key] <> BLANK() && '01 XER_TASK'[ProjectName] <> BLANK()
				            ), 
				            "Project", '01 XER_TASK'[ProjectName],
				            "wbs_id_key", '01 XER_TASK'[wbs_id_key]
				        )
				    ),
				    "ProjectCode", MAXX(FILTER('Project', 'Project'[projectname] = [Project]), 'Project'[projectno]),
				    "State", MAXX(FILTER('Project', 'Project'[projectname] = [Project]), 'Project'[State]),
				    "Level_2", MAXX(FILTER('03 XER_PROJWBS', '03 XER_PROJWBS'[wbs_id_key] = [wbs_id_key]), '03 XER_PROJWBS'[Level_2]),
				    "Level_3", MAXX(FILTER('03 XER_PROJWBS', '03 XER_PROJWBS'[wbs_id_key] = [wbs_id_key]), '03 XER_PROJWBS'[Level_3]),
				    "Level_4", MAXX(FILTER('03 XER_PROJWBS', '03 XER_PROJWBS'[wbs_id_key] = [wbs_id_key]), '03 XER_PROJWBS'[Level_4])
				)
				```

	annotation PBI_Id = 50f5c4a91ce0444bb70d1e41ee30c977

