	column ProjectId
		formatString: 0
		lineageTag: ea353b97-1a97-4a4b-97a9-0017737f893d
		summarizeBy: none
		isNameInferred
		sourceColumn: [ProjectId]

		annotation SummarizationSetBy = Automatic

	column ProjectKey
		isHidden
		lineageTag: 99d88f35-6624-45c3-b75f-cdfd209c9b5d
		summarizeBy: none
		isNameInferred
		sourceColumn: [ProjectKey]

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	partition Project_Dimension = calculated
		mode: import
		source =
				
				VAR BaseProjects =
				    DISTINCT(
				        SELECTCOLUMNS(
				            FILTER(
				                ALL('02 XER_PROJECT'),
					VAR ProjectKey = UPPER(TRIM('02 XER_PROJECT'[ProjectCode]))
				                RETURN
				                    ProjectKey <> BLANK()
				                        && ProjectKey <> ""
				            ),
					"ProjectKey", UPPER(TRIM('02 XER_PROJECT'[ProjectCode])),
					"ProjectCode", UPPER(TRIM('02 XER_PROJECT'[ProjectCode]))
				        )
				    )
				VAR WithProjectCodeVariants =
				    ADDCOLUMNS(
				        BaseProjects,
				        "DisplayProjectCode",
				            SWITCH(
				                TRUE(),
				                UPPER(LEFT([ProjectCode], 1)) = "C", "J" & MID([ProjectCode], 2, LEN([ProjectCode]) - 1),
				                [ProjectCode]
				            ),
				        "SecurityAltProjectCode",
				            SWITCH(
				                TRUE(),
				                UPPER(LEFT([ProjectCode], 1)) = "C", "J" & MID([ProjectCode], 2, LEN([ProjectCode]) - 1),
				                UPPER(LEFT([ProjectCode], 1)) = "J", "C" & MID([ProjectCode], 2, LEN([ProjectCode]) - 1),
				                BLANK()
				            )
				    )
				VAR WithProjectMetadata =
				    ADDCOLUMNS(
				        WithProjectCodeVariants,
				        "Project",
				            VAR OriginalProject =
				                LOOKUPVALUE(
				                    'dbo_project'[projectname],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            VAR PreferredProject =
				                LOOKUPVALUE(
				                    'dbo_project'[projectname],
				                    'dbo_project'[projectno], [DisplayProjectCode]
				                )
				            RETURN
				                COALESCE(PreferredProject, OriginalProject, [ProjectCode]),
				        "State",
				            VAR OriginalState =
				                LOOKUPVALUE(
				                    'dbo_project'[state],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalState),
				                    OriginalState,
				                    LOOKUPVALUE(
				                        'dbo_project'[state],
				                        'dbo_project'[projectno], [SecurityAltProjectCode]
				                    )
				                ),
				        "CompanyId",
				            VAR OriginalCompanyId =
				                LOOKUPVALUE(
				                    'dbo_project'[companyid],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalCompanyId),
				                    OriginalCompanyId,
				                    LOOKUPVALUE(
				                        'dbo_project'[companyid],
				                        'dbo_project'[projectno], [SecurityAltProjectCode]
				                    )
				                ),
				        "ProjectId",
				            VAR OriginalProjectId =
				                LOOKUPVALUE(
				                    'dbo_project'[projectid],
				                    'dbo_project'[projectno], [ProjectCode]
				                )
				            RETURN
				                IF(
				                    NOT ISBLANK(OriginalProjectId),
				                    OriginalProjectId,
				                    LOOKUPVALUE(
				                        'dbo_project'[projectid],
				                        'dbo_project'[projectno], [SecurityAltProjectCode]
				                    )
				            )
				    )
				RETURN
				    SELECTCOLUMNS(
				        WithProjectMetadata,
				        "Project", [Project],
				        "State", [State],
				        "ProjectKey", [ProjectKey],
				        "ProjectCode", [ProjectCode],
				        "CompanyId", [CompanyId],
				        "ProjectId", [ProjectId]
				)

	annotation PBI_Id = 50f5c4a91ce0444bb70d1e41ee30c977

