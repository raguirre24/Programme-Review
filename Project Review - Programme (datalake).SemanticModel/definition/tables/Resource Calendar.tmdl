table 'Resource Calendar'
	lineageTag: cf0ce51c-a579-4d64-9c3b-4e7f5880e889

	column Month
		formatString: Long Date
		lineageTag: 65d8a249-e728-4289-afe9-883bc6e405dc
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month]

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition 'Resource Calendar' = calculated
		mode: import
		source = ```
				
				VAR MonthRange =
				    FILTER (
				        UNION (
				            SELECTCOLUMNS (
				                '15_XER_RESOURCE_DISTRIBUTION',
				                "Month", '15_XER_RESOURCE_DISTRIBUTION'[distribution_month]
				            ),
				            SELECTCOLUMNS (
				                'Monthly Resource Distribution Baseline',
				                "Month", 'Monthly Resource Distribution Baseline'[distribution_month]
				            )
				        ),
				        NOT ISBLANK ( [Month] )
				    )
				VAR MinDate = MINX ( MonthRange, [Month] )
				
				VAR MaxDate = MAXX ( MonthRange, [Month] )
				RETURN
				DISTINCT (
				    SELECTCOLUMNS (
				        CALENDAR ( MinDate, MaxDate ),
				        "Month", DATE ( YEAR ( [Date] ), MONTH ( [Date] ), 1 )
				    )
				)
				
				```

	annotation PBI_Id = fe85f5eb663742e6a5d3ddc73cbdd0bc

