table 'XER Measures'
	lineageTag: 1c5bb7e0-f6a8-44e3-a17e-f631a724c979

	measure 'Variance to Previous Update' = ```
			
			VAR IsTaskSelected = HASONEVALUE('01 XER_TASK'[task_code])
			VAR IsWBSSelected = 
			    ISFILTERED('03 XER_PROJWBS'[Level_2]) || 
			    ISFILTERED('03 XER_PROJWBS'[Level_3]) || 
			    ISFILTERED('03 XER_PROJWBS'[Level_4]) || 
			    ISFILTERED('03 XER_PROJWBS'[Level_5])
			
			VAR CurrentTaskCode = IF(IsTaskSelected, SELECTEDVALUE('01 XER_TASK'[task_code]), BLANK())
			VAR CurrentProject = SELECTEDVALUE('01 XER_TASK'[ProjectName], BLANK())
			VAR CurrentMonthUpdate = SELECTEDVALUE('01 XER_TASK'[UpdateDate], BLANK())
			
			VAR SelectedTaskTypes = SELECTEDVALUE(Filter_TaskType[TaskType], "All")
			
			// FIXED: Find previous month using ALL('01 XER_TASK') to escape bidirectional filters
			VAR PreviousMonthUpdate = 
			    CALCULATE(
			        MAX('01 XER_TASK'[UpdateDate]),
			        FILTER(
			            ALL('01 XER_TASK'),
			            '01 XER_TASK'[UpdateDate] < CurrentMonthUpdate &&
			            '01 XER_TASK'[ProjectName] = CurrentProject
			        )
			    )
			
			VAR IsFirstMonth = ISBLANK(PreviousMonthUpdate)
			
			// ============================================
			// CURRENT MONTH - MAX FINISH DATE (Original Logic)
			// ============================================
			VAR FinishCurrent = 
			    SWITCH(
			        TRUE(),
			        IsTaskSelected,
			        CALCULATE(
			            MAX('01 XER_TASK'[Finish]),
			            FILTER(
			                ALL('01 XER_TASK'),
			                '01 XER_TASK'[task_code] = CurrentTaskCode &&
			                '01 XER_TASK'[UpdateDate] = CurrentMonthUpdate &&
			                '01 XER_TASK'[ProjectName] = CurrentProject &&
			                (SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes)
			            )
			        ),
			        IsWBSSelected,
			        // Original WBS logic with ALLEXCEPT
			        CALCULATE(
			            MAX('01 XER_TASK'[Finish]),
			            ALLEXCEPT('03 XER_PROJWBS',
			                '03 XER_PROJWBS'[Level_2],
			                '03 XER_PROJWBS'[Level_3],
			                '03 XER_PROJWBS'[Level_4],
			                '03 XER_PROJWBS'[Level_5]
			            ),
			            '01 XER_TASK'[UpdateDate] = CurrentMonthUpdate,
			            '01 XER_TASK'[ProjectName] = CurrentProject,
			            SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes
			        ),
			        CALCULATE(
			            MAX('01 XER_TASK'[Finish]),
			            FILTER(
			                ALL('01 XER_TASK'),
			                '01 XER_TASK'[UpdateDate] = CurrentMonthUpdate &&
			                '01 XER_TASK'[ProjectName] = CurrentProject &&
			                (SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes)
			            )
			        )
			    )
			
			// ============================================
			// PREVIOUS MONTH - MAX FINISH DATE (Original Logic)
			// ============================================
			VAR FinishPrevious = 
			    IF(
			        NOT(IsFirstMonth),
			        SWITCH(
			            TRUE(),
			            IsTaskSelected,
			            CALCULATE(
			                MAX('01 XER_TASK'[Finish]),
			                FILTER(
			                    ALL('01 XER_TASK'),
			                    '01 XER_TASK'[task_code] = CurrentTaskCode &&
			                    '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate &&
			                    '01 XER_TASK'[ProjectName] = CurrentProject &&
			                    (SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes)
			                )
			            ),
			            IsWBSSelected,
			            // Original WBS logic with ALLEXCEPT
			            CALCULATE(
			                MAX('01 XER_TASK'[Finish]),
			                ALLEXCEPT('03 XER_PROJWBS',
			                    '03 XER_PROJWBS'[Level_2],
			                    '03 XER_PROJWBS'[Level_3],
			                    '03 XER_PROJWBS'[Level_4],
			                    '03 XER_PROJWBS'[Level_5]
			                ),
			                '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate,
			                '01 XER_TASK'[ProjectName] = CurrentProject,
			                SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes
			            ),
			            CALCULATE(
			                MAX('01 XER_TASK'[Finish]),
			                FILTER(
			                    ALL('01 XER_TASK'),
			                    '01 XER_TASK'[UpdateDate] = PreviousMonthUpdate &&
			                    '01 XER_TASK'[ProjectName] = CurrentProject &&
			                    (SelectedTaskTypes = "All" || '01 XER_TASK'[TaskType_Classified] = SelectedTaskTypes)
			                )
			            )
			        ),
			        BLANK()
			    )
			
			// ============================================
			// RETURN VARIANCE
			// ============================================
			RETURN
			    IF(
			        IsFirstMonth,
			        0,
			        IF(
			            AND(NOT(ISBLANK(FinishCurrent)), NOT(ISBLANK(FinishPrevious))),
			            IF(
			                FinishCurrent = FinishPrevious,
			                0,
			                NETWORKDAYS(FinishPrevious, FinishCurrent)
			            ),
			            BLANK()
			        )
			    )
			```
		formatString: 0
		lineageTag: 6ba58ba7-c860-478c-ab62-c667ee1ca436

	measure ShowDuration =
			
