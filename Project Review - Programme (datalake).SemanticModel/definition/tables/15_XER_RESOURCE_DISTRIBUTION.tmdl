	column ProjectCode
		dataType: string
		lineageTag: c62bd8a5-5b13-4a6e-8ab0-887addc54dc5
		summarizeBy: none
		sourceColumn: ProjectCode

		annotation SummarizationSetBy = Automatic

	column monthly_hours =
			
			VAR Qty = '15_XER_RESOURCE_DISTRIBUTION'[monthly_quantity]
			VAR RsrcType = '15_XER_RESOURCE_DISTRIBUTION'[rsrc_type]
			VAR QtyPerHr = VALUE(LOOKUPVALUE('12_XER_RSRC'[def_qty_per_hr], '12_XER_RSRC'[rsrc_id_key], '15_XER_RESOURCE_DISTRIBUTION'[rsrc_id_key]))
			RETURN
			    IF(
			        RsrcType = "RT_Labor",
			        IF(QtyPerHr <> 0, Qty / QtyPerHr, Qty),
			        Qty
			    )
		formatString: #,0.00
		lineageTag: d2e4f6a8-b0c2-4d6e-8f01-234567890abc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	partition 15_XER_RESOURCE_DISTRIBUTION = m
		mode: import
		queryGroup: XER
		source =
				let
				    Source =
				        fnAthenaSource(
				            "15_xer_resource_distribution",
				            Text.Combine(
				                {
				                    "t.""task_id_key""",
				                    "t.""rsrc_id_key""",
				                    "t.""is_actual""",
				                    "t.""distribution_month""",
				                    "t.""rsrc_name""",
				                    "t.""rsrc_type""",
				                    "t.""unit""",
				                    "t.""monthly_quantity""",
				                    "SPLIT_PART(t.""filename"", '-', 1) AS ""ProjectCode"""
				                },
				                ", "
				            )
				        ),
				    Typed = Table.TransformColumnTypes(Source, {
				        {"distribution_month", type date},
				        {"monthly_quantity", type number}
				    }),
				    ReplacedUnits = Table.ReplaceValue(     // ← NEW STEP
				        Typed,
				        each [unit],
				        each if [rsrc_type] = "RT_Labor" and [unit] = "unit/time"
				             then "hours"
				             else [unit],
				        Replacer.ReplaceValue,
				        {"unit"}
				    ),
				    SelectedColumns = Table.SelectColumns(ReplacedUnits, {  // ← updated reference
				        "task_id_key", "rsrc_id_key", "is_actual", "distribution_month",
				        "rsrc_name", "rsrc_type",
				        "unit", "monthly_quantity", "ProjectCode"
				    })
				in
				    SelectedColumns

	annotation PBI_Id = 67b96e3bda7547809e01d736027b8fa7

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

