table 15_XER_RESOURCE_DISTRIBUTION
	lineageTag: 87556888-48ae-43af-af95-ce6b18405b46

	column task_id_key
		dataType: string
		lineageTag: 5407ad4a-1bd8-4072-9689-24bffc1fe1d3
