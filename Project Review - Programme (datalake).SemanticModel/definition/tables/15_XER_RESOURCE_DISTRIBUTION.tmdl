		lineageTag: ca303599-4d1a-48f5-a39a-e303665893fd
		summarizeBy: none
		sourceColumn: rsrc_id_key

		annotation SummarizationSetBy = Automatic

	column is_actual
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 1b796626-b81e-4475-b92e-0fd47ad7133b
		summarizeBy: none
		sourceColumn: is_actual

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column distribution_month
		dataType: dateTime
		formatString: Long Date
		lineageTag: 101cb4d5-156e-45ea-93d7-534ff1d83a3f
		summarizeBy: none
		sourceColumn: distribution_month

		annotation SummarizationSetBy = Automatic

