role 'Project Access 3'
	modelPermission: read

	tablePermission Project_Dimension = ```
			VAR CurrentUser = LOWER(USERPRINCIPALNAME())
			
			VAR CurrentUserPermissions = 
			    FILTER(
			        'UserPermission',
			        LOWER('UserPermission'[UserPrincipalName]) = CurrentUser || 
			        LOWER('UserPermission'[ExternalUserPrincipalName]) = CurrentUser
			    )
			
			VAR HasAllAccess =
			    COUNTROWS(
			        FILTER(
			            CurrentUserPermissions,
			            'UserPermission'[All Access] = 1
			        )
			    ) > 0
			
			RETURN IF(HasAllAccess, TRUE(),
			    
			    VAR AllowedStates = 
			        SELECTCOLUMNS(
			            FILTER(
			                CurrentUserPermissions,
			                'UserPermission'[All Access] = 2
			            ),
			            "State", 'UserPermission'[State]
			        )
			
			    VAR AllowedProjects = 
			        SELECTCOLUMNS(
			            FILTER(
			                CurrentUserPermissions,
			                'UserPermission'[All Access] = 3
			            ),
			            "ProjectCode", 'UserPermission'[ProjectCode]
			        )
			
			    VAR IsStateMatch = 'Project_Dimension'[State] IN AllowedStates
			    VAR IsProjectMatch = 'Project_Dimension'[ProjectCode] IN AllowedProjects
			
			    RETURN IsStateMatch || IsProjectMatch
			)
			```

	annotation PBI_Id = 52f062d5c7544bf2b206201ad84746d8

