role 'Project Access 3'
	modelPermission: read

	tablePermission Project

	tablePermission Project_Dimension = ```
			-- Identify the current user and convert to lowercase immediately.
			VAR CurrentUser = LOWER(USERPRINCIPALNAME())
			
			-- Retrieve all permission rows. CRITICAL FIX: We must check BOTH internal and external UPN columns.
			VAR CurrentUserPermissions = 
			    FILTER(
			        'UserPermission',
			        LOWER('UserPermission'[UserPrincipalName]) = CurrentUser || 
			        LOWER('UserPermission'[ExternalUserPrincipalName]) = CurrentUser
			    )
			
			-- 1. Check for All Access (Level 1).
			VAR HasAllAccess =
			    COUNTROWS(
			        FILTER(
			            CurrentUserPermissions,
			            'UserPermission'[All Access] = 1
			        )
			    ) > 0
			
			-- Performance Optimization: If All Access is granted, stop checking immediately (Short-Circuit).
			RETURN IF(HasAllAccess, TRUE(),
			    
			    -- 2. Gather State Level Access (Level 2)
			    VAR AllowedStates = 
			        SELECTCOLUMNS(
			            FILTER(
			                CurrentUserPermissions,
			                'UserPermission'[All Access] = 2
			            ),
			            "State", 'UserPermission'[State]
			        )
			
			    -- 3. Gather Project Specific Access (Level 3)
			    VAR AllowedProjects = 
			        SELECTCOLUMNS(
			            FILTER(
			                CurrentUserPermissions,
			                'UserPermission'[All Access] = 3
			            ),
			            "ProjectID", 'UserPermission'[ProjectID]
			        )
			
			    -- Check if the current Project row matches allowed States OR allowed Projects.
			    VAR IsStateMatch = 'Project_Dimension'[State] IN AllowedStates
			    VAR IsProjectMatch = 'Project_Dimension'[Project] IN AllowedProjects
			
			    RETURN IsStateMatch || IsProjectMatch
			)
			```

	annotation PBI_Id = 52f062d5c7544bf2b206201ad84746d8

