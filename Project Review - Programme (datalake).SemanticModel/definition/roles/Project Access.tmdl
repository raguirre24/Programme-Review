role 'Project Access'
	modelPermission: read

	tablePermission Project_Dimension =
			VAR RawUPN =
			    LOWER ( USERPRINCIPALNAME () )
			
			VAR ExtTagPos =
			    SEARCH ( "#ext#", RawUPN, 1, 0 )
			
			VAR RecoveredEmail =
			    IF (
			        ExtTagPos > 0,
			        SUBSTITUTE ( LEFT ( RawUPN, ExtTagPos - 1 ), "_", "@", 1 ),
			        RawUPN
			    )
			
			VAR AtPos =
			    SEARCH ( "@", RecoveredEmail, 1, 0 )
			
			VAR LocalPart =
			    IF ( AtPos > 0, LEFT ( RecoveredEmail, AtPos - 1 ), "" )
			
			VAR DomainPart =
			    IF ( AtPos > 0, MID ( RecoveredEmail, AtPos, LEN ( RecoveredEmail ) ), "" )
			
			VAR EmailNoExt =
			    IF (
			        AtPos > 4
			            && RIGHT ( LocalPart, 4 ) = ".ext",
			        LEFT ( LocalPart, LEN ( LocalPart ) - 4 ) & DomainPart,
			        RecoveredEmail
			    )
			
			VAR UserIdentifiers =
			    { RawUPN, RecoveredEmail, EmailNoExt }
			
			VAR CurrentProjectState =
			    LOWER ( 'Project_Dimension'[State] )
			
			VAR CurrentUserPermissions =
			    FILTER (
			        ALL ( 'dbo_userpermission' ),
			        LOWER ( 'dbo_userpermission'[linkedsite_email] ) IN UserIdentifiers
			            || LOWER ( 'dbo_userpermission'[userprincipalname] ) IN UserIdentifiers
			    )
			
			VAR HasAllAccess =
			    COUNTROWS (
			        FILTER (
			            CurrentUserPermissions,
			            ISBLANK ( 'dbo_userpermission'[projectid] )
			                && ( ISBLANK ( 'dbo_userpermission'[region] ) || 'dbo_userpermission'[region] = "" )
			                && ISBLANK ( 'dbo_userpermission'[companyid] )
			        )
			    ) > 0
			
			VAR HasStateAccess =
			    COUNTROWS (
			        FILTER (
			            CurrentUserPermissions,
			            ISBLANK ( 'dbo_userpermission'[projectid] )
			                && NOT ISBLANK ( 'dbo_userpermission'[region] )
			                && 'dbo_userpermission'[region] <> ""
			                && LOWER ( 'dbo_userpermission'[region] ) = CurrentProjectState
			        )
			    ) > 0
			
			VAR HasProjectAccess =
			    'Project_Dimension'[ProjectCode]
			        IN SELECTCOLUMNS (
			            FILTER (
			                CurrentUserPermissions,
			                NOT ISBLANK ( 'dbo_userpermission'[projectid] )
			                    && NOT ISBLANK ( 'dbo_userpermission'[projectno] )
			            ),
			            "AllowedProjectNo", 'dbo_userpermission'[projectno]
			        )
			
			RETURN
			    HasAllAccess
			        || HasStateAccess
			        || HasProjectAccess

	annotation PBI_Id = d8d20f5b9cdf4286af9ca1b71c029851

